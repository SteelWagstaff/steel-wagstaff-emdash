---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { entries: tracks, cacheHint } = await getEmDashCollection("music");

Astro.cache.set(cacheHint);

const sorted = tracks.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const formatDate = (date: Date | null | undefined) => {
	if (!date) return null;
	return date.toLocaleDateString("en-US", { year: "numeric", month: "long" });
};
---

<Base title="Music" description="Playlists, mixtapes, and listening notes from Steel Wagstaff">
	<div class="posts-page">
		<header class="page-header">
			<h1 class="page-title">Music</h1>
			<p class="page-description">
				Playlists, mixtapes, and listening notes &mdash; {sorted.length} entries
			</p>
		</header>

		{
			sorted.length === 0 ? (
				<p class="empty">No music entries yet.</p>
			) : (
				<div class="posts-list">
					{sorted.map((entry) => (
						<article class="post-item">
							<a href={`/music/${entry.id}`} class="post-link">
								<div class="post-meta">
									{entry.data.publishedAt && (
										<time>{formatDate(entry.data.publishedAt)}</time>
									)}
								</div>
								<h2 class="post-title">{entry.data.title}</h2>
								{entry.data.excerpt && (
									<p class="post-excerpt">{entry.data.excerpt}</p>
								)}
							</a>
						</article>
					))}
				</div>
			)
		}
	</div>
</Base>
