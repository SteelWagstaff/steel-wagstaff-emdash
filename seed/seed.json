										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-45-x14nu",
									"text": " (Orofino): D"
								},
								{
									"_type": "span",
									"_key": "key-46-poxwr",
									"text": "id a foreign exchange in Tokyo his senior year of high school. Went to Stanford for undergrad, majored in Japanese. M"
								},
								{
									"_type": "span",
									"_key": "key-47-f001k",
									"text": "oved to Orange County, worked in sales and marketing for a small scientific research company. In 2011, enrolled in law school at NYU. Just finished."
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-52-m464e",
