							]
						},
						{
							"_type": "block",
							"_key": "key-91-mdbw6",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-89-ccl0j",
									"text": "Smart on Crime",
									"marks": [
										"key-88-57qfo",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-90-r222j",
									"text": "Being tough on criminals hasn’t worked, but neither has being lenient. Here’s how to prevent—and punish—crime the right way.  When I was young and irresponsible, I met with the domestic policy team of a Democratic presidential nominee.",
									"marks": [
										"strong"
									]
