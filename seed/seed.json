				"id": "music:75-songs-best-of-january-february-2015",
				"slug": "75-songs-best-of-january-february-2015",
				"status": "published",
				"data": {
					"title": "75 Songs [Best of January &amp; February 2015]",
					"featured_image": {
						"id": "",
						"provider": "external",
						"src": "https://steelwagstaff.info/wordpress/wp-content/uploads/2016/11/IMG_3334.jpg"
					},
					"content": [
						{
							"_type": "block",
							"_key": "k1",
							"style": "normal",
							"markDefs": [],
							"children": [
								{
									"_type": "span",
									"_key": "k0",
									"text": "Here are 75 songs I listened to and liked in January and February of 2015. Cold months in Wisconsin, they were, but still some nice music in there for me, though not a ton of variety. I really liked the newest Clap Your Hands Say Yeah record Only Run, as well as Hurray for the Riff Raff's Small Town Heroes, Thus Owls' Turning Rocks album, J.E. Sunde's Shapes That Kiss the Lips of God, and PHOX's PHOX [both are from Northern Wisconsin!]. I also listened to a ton of Saintseneca, Marissa Nadler and John Fullbright (the last two were both new discoveries for me). Enjoy!",
									"marks": []
								}
							]
						},
						{
							"_type": "block",
							"_key": "k3",
							"style": "normal",
							"markDefs": [],
							"children": [
								{
									"_type": "span",
									"_key": "k2",
									"text": "http://open.spotify.com/user/steelwagstaff/playlist/0EIwJ84UbT8GP6GvVz92Di",
									"marks": []
								}
							]
						}
					]
				}
			},
