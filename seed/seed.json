										"key-122-esl0u",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-124-h8lhd",
									"text": " by Edward Luce",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-125-ywy01",
									"text": "A youthful 60, with mildly thinning hair, Michael Sandel is dressed in the garb of the academic: slacks, light blue shirt, drab jacket and no tie.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-122-esl0u",
									"href": "http://www.ft.com/intl/cms/s/2/bd509112-9c55-11e2-9a4b-00144feabdc0.html#axzz2PcH5smwa"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-131-oojeu",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-128-gi565",
									"text": "Silicon Valley’s Start-Up Machine",
									"marks": [
										"key-127-s16jw",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-129-o6cim",
									"text": " by Nathaniel Rich",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-130-9ogx3",
									"text": "Michelle Crosby, an energetic 37-year-old lawyer in Boise, Idaho, applied for a loan last November from a local bank, Western Capital. She proposed to use the money, $10,000, to help start a new business, Wevorce, which could be described most reductively as an H&R Block for divorces.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
