							"children": [
								{
									"_type": "span",
									"_key": "key-1-zf44y",
									"text": "The cello breaks my heart open, and the two voices mend it again.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-2-yjh8o",
									"text": "https://www.youtube.com/watch?v=QgxCH9xMhgc\n\n"
								},
								{
									"_type": "span",
									"_key": "key-3-yocqy",
									"text": "Photo by "
								},
								{
									"_type": "span",
									"_key": "key-5-8xk62",
									"text": "gleb sarkisov",
									"marks": [
										"key-4-ymy63"
									]
								},
								{
									"_type": "span",
									"_key": "key-6-8zu2c",
									"text": " "
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-4-ymy63",
									"href": "http://www.flickr.com/photos/60454024@N05/14671155640",
									"blank": true
								},
								{
									"_type": "link",
