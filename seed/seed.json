						{
							"_type": "block",
							"_key": "key-198-zzz9r",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-191-masyq",
									"text": " Laurel and Mike discuss how and when exactly Mike plans to \"drop the bass.\"[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-192-brcxf",
									"text": "The dancing began with Laurel and I taking the floor alone as Patti Griffin's song "
								},
								{
									"_type": "span",
									"_key": "key-194-zn57z",
									"text": "\"Not Alone\"",
									"marks": [
										"key-193-ftohv"
									]
								},
								{
									"_type": "span",
									"_key": "key-195-koys5",
