									"blank": true
								},
								{
									"_type": "link",
									"_key": "key-46-ozhsi",
									"href": "https://www.rogueamoeba.com/soundsource/buy.php",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-65-x8rm8",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-51-2jdjm",
									"text": "Soundflower",
									"marks": [
										"key-50-n2966"
									]
								},
								{
									"_type": "span",
									"_key": "key-52-utpw6",
									"text": ": This free kernel extension for Mac OS lets you mix two or more audio streams into a single stream so that you can record both your own microphone and the people you are talking with in a single application. It’s now being maintained on "
								},
								{
									"_type": "span",
									"_key": "key-54-zsg66",
									"text": "GitHub",
									"marks": [
										"key-53-07jos"
									]
								},
								{
									"_type": "span",
									"_key": "key-55-qgrxj",
									"text": " by "
								},
								{
									"_type": "span",
									"_key": "key-57-qnnsy",
									"text": "Matt Ingalls",
									"marks": [
										"key-56-ybj25"
									]
								},
								{
									"_type": "span",
									"_key": "key-58-3cyxa",
									"text": ". Rogue Ameoba now sells a similar but even more powerful product called "
								},
								{
									"_type": "span",
									"_key": "key-60-4gken",
									"text": "Loopback",
									"marks": [
										"key-59-pl18b"
									]
								},
								{
									"_type": "span",
									"_key": "key-61-arxl1",
									"text": " (which costs "
								},
								{
									"_type": "span",
									"_key": "key-63-eo2lt",
									"text": "$99",
									"marks": [
										"key-62-i0aw0"
									]
								},
								{
									"_type": "span",
									"_key": "key-64-xndoi",
									"text": " for a new license)"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-50-n2966",
									"href": "https://www.rogueamoeba.com/freebies/soundflower/",
									"blank": true
								},
								{
									"_type": "link",
									"_key": "key-53-07jos",
									"href": "https://github.com/mattingalls/Soundflower",
									"blank": true
								},
								{
