									]
								},
								{
									"_type": "span",
									"_key": "key-55-z0lmw",
									"text": ". I'm afraid to confess that I found this book boring as hell."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-53-x2u58",
									"href": "https://global.oup.com/academic/product/the-dead-sea-scrolls-a-very-short-introduction-9780198779520?q=dead%20sea%20scrolls&lang=en&cc=us",
