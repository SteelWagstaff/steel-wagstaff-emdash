							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-152-yue9a",
									"text": " Table #2 with floral centerpiece behind[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-153-nbdzo",
									"text": "Laurel and I sat at a smaller table near the center of the room reserved just for us, which was lovingly adorned with flowers by Laurel's sisters and friends.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-154-z96a4",
									"text": "[caption id=\"attachment_869\" align=\"alignleft\" width=\"500\"]"
								}
							],
							"markDefs": [
