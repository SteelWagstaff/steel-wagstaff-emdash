									"_key": "key-172-t1rao",
									"href": "http://www.thenation.com/article/secret-library-hope#axzz2WRbMegu5"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-181-gsax0",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-178-zp156",
									"text": "How Do Physicians and Non-Physicians Want to Die?",
									"marks": [
										"key-177-mm9ad",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-179-e0tdx",
									"text": " by Lisa Wade",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-180-ewpgp",
									"text": "We’re celebrating the end of the year with our most popular posts from 2013, plus a few of our favorites tossed in.  Enjoy!  A recent RadioLab podcast, titled The Bitter End, identified an interesting paradox.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-177-mm9ad",
									"href": "http://thesocietypages.org/socimages/2013/06/24/how-do-physicians-and-non-physicians-want-to-die/?utm_source=feedburner&utm_medium=feed&utm_campaign=Feed%3A+SociologicalImagesSeeingIsBelieving+%28Sociological+Images%3A+Seeing+Is+Believing%29"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-186-tg41b",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-183-aaac4",
									"text": "History Detected",
									"marks": [
										"key-182-dwirx",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-184-0zhl3",
									"text": " by Theresa Johnston",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-185-ggkmf",
									"text": "In the 1986 comedy Ferris Bueller's Day Off, Ben Stein famously plays a high school teacher who drones on about the 1930 Smoot-Hawley Tariff Act while his students slump at their desks in a collective stupor.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-182-dwirx",
									"href": "http://alumni.stanford.edu/get/page/magazine/article/?article_id=61541"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-190-1au4e",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-188-yhtkb",
									"text": "The best magazine issue you'll see this year",
									"marks": [
										"key-187-n7y0i",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-189-cnee2",
									"text": "In most regions of Afghanistan, women can't practice the arts. Religious and political restrictions bring beatings or worse for singing, acting, writing, or reciting works. You likely know this much or you could have guessed it.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-187-n7y0i",
									"href": "http://feedproxy.google.com/~r/GreetingsFromEvanstonIll/~3/UE8y31BTUJY/the-best-magazine-issue-youll-see-this-year.html"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-195-ryjxh",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-192-bu0sp",
									"text": "John Gray’s ‘Silence of Animals’",
									"marks": [
										"key-191-qzd19",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-193-i0x9m",
									"text": " by Thomas Nagel",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-194-oowcf",
									"text": "John Gray’s “Silence of Animals” is an attack on humanism. He condemns this widely accepted secular faith as a form of delusional self-flattery.          228 pp. Farrar, Straus & Giroux. $26.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-191-qzd19",
