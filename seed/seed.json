									"href": "https://www.drawnandquarterly.com/picture-this",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-75-lplak",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-71-raguj",
									"text": "Brian Vaughan and Niko Henrichon's "
								},
								{
									"_type": "span",
									"_key": "key-73-ncxwu",
									"text": "Pride of Baghdad",
									"marks": [
										"em",
										"key-72-9a4wd"
									]
								},
								{
									"_type": "span",
									"_key": "key-74-ac1ir",
									"text": ". A friend gave it to me and said, I think you'll like this. Sadly, I didn't."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-72-9a4wd",
									"href": "http://www.vertigocomics.com/graphic-novels/pride-of-baghdad",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-80-riz9j",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-76-jkbu7",
									"text": "Ted Rall's "
								},
								{
									"_type": "span",
									"_key": "key-78-jzhz8",
									"text": "After We Kill You, We Will Welcome You Back As Honored Guests: Unembedded In Afghanistan",
									"marks": [
										"em",
										"key-77-3877e"
									]
								},
								{
									"_type": "span",
									"_key": "key-79-ajwov",
									"text": ". I think Rall may be right in many of his foreign policy criticisms, but he seems like an insufferable narcissist in this book. My least favorite of all the books I read this month."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-77-3877e",
									"href": "https://www.amazon.com/After-Kill-Welcome-Honored-Guests/dp/0809023407",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-82-zegp9",
							"style": "h3",
							"children": [
								{
									"_type": "span",
									"_key": "key-81-zhb1r",
									"text": "Currently Reading"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-84-4kgyd",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-83-3nbfd",
									"text": "I’ve started a few other books that I’m reading more slowly. Each is excellent:"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-90-fq0xt",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-85-q1usz",
									"text": "Mary Beard’s "
								},
								{
									"_type": "span",
									"_key": "key-87-auv6z",
									"text": "SPQR: A History of Ancient Rome",
									"marks": [
										"em",
										"key-86-s9gpb"
									]
								},
								{
									"_type": "span",
									"_key": "key-88-ddml6",
									"text": ". ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-89-1upfb",
									"text": "Slow going, but Beard is an excellent historian and storyteller."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-86-s9gpb",
									"href": "http://books.wwnorton.com/books/SPQR/",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-94-gkiga",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-91-0fst6",
									"text": "Rebecca Solnit's "
								},
								{
									"_type": "span",
									"_key": "key-92-brk8k",
									"text": "Hope in the Dark",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-93-ktbp2",
									"text": ". Necessary reading in our current moment. I admire the mind and voice of Rebecca Solnit very, very much."
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-101-k6ivu",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-95-pt1k2",
									"text": "Jonathan Haidt's "
								},
								{
									"_type": "span",
									"_key": "key-96-t53kb",
									"text": "The Righteous Mind: Why Good People are Divided by Politics and Religion",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-97-s3i1w",
									"text": ". I'm still curious rather than fully convinced by Haidt's central arguments, though I have been enjoying the self-assessments at "
								},
								{
									"_type": "span",
									"_key": "key-99-kjgqf",
									"text": "YourMorals",
									"marks": [
										"key-98-z64ai"
									]
								},
								{
									"_type": "span",
									"_key": "key-100-h2lcd",
									"text": "."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-98-z64ai",
									"href": "http://www.yourmorals.org/",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-105-mujtn",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-102-1ano7",
									"text": "Isabel Wilkerson’s "
								},
								{
									"_type": "span",
									"_key": "key-103-pzgk8",
									"text": "The Warmth of Other Sons. ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-104-fdr8m",
									"text": "Not very deep into the book yet, but impressed so far."
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-107-m7zxc",
							"style": "h3",
							"children": [
								{
									"_type": "span",
									"_key": "key-106-yte4k",
									"text": "To Read Soon"
								}
