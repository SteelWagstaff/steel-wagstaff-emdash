									"href": "http://steelwagstaff.files.wordpress.com/2012/05/7207522696_9f91d20a15_o.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-162-7tqv6",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/05/7207522696_9f91d20a15_o.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/05/7207522696_9f91d20a15_o.jpg"
							},
							"alt": ""
						},
						{
							"_type": "block",
							"_key": "key-167-4vvif",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-163-kybw1",
									"text": " Our table. Photo by Jennie Bastian.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-164-p47v4",
									"text": "As for the program itself, we had invited guests to arrive at 5pm. Most did (some even came a little early!), and since we didn't have a formal reception line, we moved freely through the room, joining and leaving conversations, greeting guests as they arrived.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-165-iiexg",
									"text": "[caption id=\"attachment_867\" align=\"alignleft\" width=\"500\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-166-dk9hk",
									"href": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-526.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-168-ntyda",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-526.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-526.jpg"
							},
							"alt": ""
						},
						{
							"_type": "block",
							"_key": "key-176-gg2lu",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-169-kudqh",
									"text": " My handwritten itinerary for the reception.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-170-qcnfd",
									"text": "We started the evening with appetizers (the evening's food was catered by "
								},
								{
									"_type": "span",
									"_key": "key-172-fqiq6",
									"text": "Working Class Catering",
									"marks": [
										"key-171-x8lz9"
									]
								},
								{
									"_type": "span",
									"_key": "key-173-x9smi",
									"text": ", more about them in a later post on food). A buffet dinner with three vegetarian options was served around 6:30, followed by a short video of the wedding ceremony (since most of the wedding reception guests had not attended the wedding) and toasts from anyone who wanted to speak.\n"
								},
								{
									"_type": "span",
									"_key": "key-174-mp2o6",
									"text": "[caption id=\"attachment_874\" align=\"alignleft\" width=\"500\"]"
								}
							],
							"markDefs": [
