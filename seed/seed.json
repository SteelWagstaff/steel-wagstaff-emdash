							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-82-rshqf",
									"text": " View of the Merrill Lynch and Evjue rooms from rear wall. My sisters Bonnie and Camille are apparently dancing by themselves while most guests finish their dinner.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-83-cf5qb",
									"text": "We made our "
								},
								{
									"_type": "span",
									"_key": "key-85-3yxeo",
									"text": "reservation arrangements",
									"marks": [
										"key-84-jggwb"
									]
								},
								{
									"_type": "span",
									"_key": "key-86-xfy6q",
									"text": " through Kristi Kading, who also trained us on how to use the A/V equipment (the room has a projector and powerful stereo speakers) and helped us select the table settings.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-87-ucx9s",
									"text": "[caption id=\"attachment_864\" align=\"alignleft\" width=\"500\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-84-jggwb",
									"href": "http://www.goodmancenter.org/services/reserving-rooms"
								},
								{
									"_type": "link",
									"_key": "key-88-yiwsr",
									"href": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-581.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-90-p1fk4",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-581.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-581.jpg"
							},
							"alt": ""
