							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-252-7qlar",
									"text": "The Intelligent Plant",
									"marks": [
										"key-251-frg15",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-253-yvhmx",
									"text": " by Michael Pollan",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-254-1xlca",
									"text": "In 1973, a book claiming that plants were sentient beings that feel emotions, prefer classical music to rock and roll, and can respond to the unspoken thoughts of humans hundreds of miles away landed on the New York Times best-seller list for nonfiction.",
									"marks": [
										"strong"
									]
