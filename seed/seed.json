						{
							"_type": "block",
							"_key": "key-161-55qk2",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-158-tzxun",
									"text": "Some of My Best Friends Are Germs",
									"marks": [
										"key-157-0v1oi",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-159-w03ri",
									"text": " by MICHAEL POLLAN",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-160-4fnie",
									"text": "I can tell you the exact date that I began to think of myself in the first-person plural — as a superorganism, that is, rather than a plain old individual human being. It happened on March 7.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-157-0v1oi",
									"href": "http://www.nytimes.com/2013/05/19/magazine/say-hello-to-the-100-trillion-bacteria-that-make-up-your-microbiome.html?pagewanted=all&_r=0"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-166-2wowr",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-163-24hom",
									"text": "The Gay Guide to Wedded Bliss",
									"marks": [
										"key-162-7jzlz",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-164-88qx5",
									"text": " by Liza Mundy",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-165-lhs06",
									"text": "Research finds that same-sex unions are happier than heterosexual marriages.",
									"marks": [
										"strong"
									]
