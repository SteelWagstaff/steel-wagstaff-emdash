							]
						},
						{
							"_type": "image",
							"_key": "key-9-94ga0",
							"asset": {
								"_type": "reference",
								"_ref": "https://steelwagstaff.info/wordpress/wp-content/plugins/wp-inject/images/cc.png",
								"url": "https://steelwagstaff.info/wordpress/wp-content/plugins/wp-inject/images/cc.png"
