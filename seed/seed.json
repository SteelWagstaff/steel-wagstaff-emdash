							"_key": "key-106-boytl",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-103-rdwlu",
									"text": "California Bill Seeks Campus Credit for Online Study",
									"marks": [
										"key-102-69u7l",
										"strong"
									]
								},
								{
