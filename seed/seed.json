							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-242-xbhv7",
									"text": "The Man Who Would Teach Machines to Think",
									"marks": [
										"key-241-01qyk",
										"strong"
									]
