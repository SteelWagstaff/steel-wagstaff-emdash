										"key-97-n5yol",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-99-51qw2",
									"text": " by GARY GUTTING",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-100-2h12s",
									"text": "An old friend and mentor of mine, Ernan McMullin, was a philosopher of science widely respected in his discipline.  He was also a Catholic priest.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
