					"content": [
						{
							"_type": "block",
							"_key": "key-2-9w9ve",
							"style": "h2",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-2yisn",
									"text": "Books"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-4-1n9u9",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-3-c9l3v",
									"text": "I wrote last month that I was on a big reading kick, and that surge of devouring books has continued in full force this month. Outside of the reading I've been doing for my dissertation and my work, here's a list of the books I read for pleasure/self-education in October 2016:"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-9-95r86",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-6-0l1ar",
									"text": "No Good Men Among the Living",
									"marks": [
										"em",
										"key-5-0196w"
									]
								},
								{
									"_type": "span",
									"_key": "key-7-ymvoe",
									"text": " ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-8-fnota",
									"text": "by Anand Gopal. An account of the war in Afghanistan, told largely through the lens of 3 native Afghans. Important, detailed reporting from a WSJ journalist who lived and reported in Afghanistan for several years. Read on recommendation from my friend Laura."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-5-0196w",
									"href": "http://anandgopal.com/sales-links/",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-16-g94lg",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-11-kz606",
									"text": "Partisan of Things",
									"marks": [
										"em",
										"key-10-arbw8"
									]
								},
								{
									"_type": "span",
									"_key": "key-12-8l5hv",
									"text": " ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-13-ir0b4",
									"text": "by Francis Ponge. Translated by Joshua Corey and Jean-Luc Garneau. A new translation of Ponge's amazing 1942 collection of prose poems "
								},
								{
									"_type": "span",
									"_key": "key-14-47ze3",
									"text": "Le parti pris de choses",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-15-oy36l",
									"text": " from Kenning Press. Absolutely worthy reading."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-10-arbw8",
									"href": "http://www.joshua-corey.com/partisan-of-things/",
