										"key-38-68vlv",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-40-u0cbj",
									"text": " by Joan Acocella",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-41-z2230",
									"text": "“Why you?” a man asked Francesco di Bernardone, known to us now as St. Francis of Assisi. Francis (1181/2-1226) was scrawny and plain-looking. He wore a filthy tunic, with a piece of rope as a belt, and no shoes.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
