							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-59-oejws",
									"text": "Ezra Klein: The Wise Boy A tale of striving and success in modern-day Washington",
