							"_key": "key-171-lcbo5",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-168-to8sv",
									"text": "Katrina's Hidden Race War | The Nation",
									"marks": [
										"key-167-8f0x3",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-169-yors6",
									"text": " by A.C. Thompson",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-170-1a50v",
									"text": "White vigilante justice tore through New Orleans after the storm. But no official investigation has shed light on the violence.  A.C. Thompson's reporting on New Orleans was directed and underwritten by the Investigative Fund at The Nation Institute.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
