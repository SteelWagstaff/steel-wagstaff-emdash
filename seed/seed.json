									"href": "http://www.snowlionpub.com/html/product_9684.html"
								}
							]
						}
					]
				}
			},
			{
				"id": "posts:mark-nowak",
				"slug": "mark-nowak",
				"status": "published",
				"data": {
					"title": "Mark Nowak",
					"featured_image": {
						"provider": "external",
						"id": "",
						"src": "https://steelwagstaff.info/wordpress/wp-content/uploads/2011/05/mark_nowak.jpg"
					},
					"content": [
						{
							"_type": "block",
							"_key": "key-9-8gt0u",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-8l4n6",
									"text": "So, among other things, I'm going to start on ongoing series of features on this blog, one of which will be posts about my favorite artists, called, appropriately enough, \"My Favorite People Series.\" This post is the first in what I hope will be a long line of posts about all kinds of people that I admire and respect. The first artist (documentary poet, social critic, labor activist, blogger) I want to write about, Mark Nowak, is someone that I would class as a friend, in addition to being one of my favorite poets. In fact, I interviewed Mark over the holiday break in January 2010 for "
								},
								{
									"_type": "span",
									"_key": "key-3-vk6ju",
									"text": "Contemporary Literature",
									"marks": [
										"em",
										"key-2-ksdis"
									]
								},
								{
									"_type": "span",
									"_key": "key-4-f00c5",
									"text": ", and "
								},
								{
									"_type": "span",
									"_key": "key-6-j3y65",
									"text": "that interview",
									"marks": [
										"key-5-4im0m"
									]
								},
								{
									"_type": "span",
									"_key": "key-7-kyh5a",
									"text": " was my first publication in an academic journal, so it's fitting that I start this series with a feature on Mark.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-8-5pp8b",
									"text": "[caption id=\"attachment_6002\" align=\"alignright\" width=\"600\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-2-ksdis",
									"href": "http://uwpress.wisc.edu/journals/journals/cl.html"
								},
								{
									"_type": "link",
									"_key": "key-5-4im0m",
									"href": "http://steelwagstaff.files.wordpress.com/2011/05/nowak_interview.pdf"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-10-sdprn",
							"asset": {
								"_type": "reference",
								"_ref": "https://steelwagstaff.info/wordpress/wp-content/uploads/2011/05/mark_nowak-600x450.jpg",
								"url": "https://steelwagstaff.info/wordpress/wp-content/uploads/2011/05/mark_nowak-600x450.jpg"
							},
							"alt": "Mark Nowak"
						},
						{
							"_type": "block",
							"_key": "key-79-7dl00",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-11-82gtj",
									"text": "Mark Nowak[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-12-zrttg",
									"text": "If you can't be bothered to read "
								},
								{
									"_type": "span",
									"_key": "key-14-5lc7w",
									"text": "the interview",
									"marks": [
										"key-13-7n1it"
									]
								},
								{
									"_type": "span",
									"_key": "key-15-vwp5h",
									"text": " (and I really think you should), here's a brief bio: Mark was born and raised in a working-class, predominantly Polish neighborhood in Buffalo, New York and as a teenager hoped to make a living fronting a local punk band, before slowly gravitating toward poetry. He earned his MFA at Bowling Green State University (where he studied with "
								},
								{
									"_type": "span",
									"_key": "key-17-97gj9",
									"text": "Ted Enslin",
									"marks": [
										"key-16-gj1vq"
									]
								},
								{
									"_type": "span",
									"_key": "key-18-h75tw",
									"text": ", another one of my favorite artists), taught for several years at "
								},
								{
									"_type": "span",
									"_key": "key-20-5w61s",
									"text": "St. Catherine University",
									"marks": [
										"key-19-0r1mz"
									]
								},
								{
									"_type": "span",
									"_key": "key-21-hzbws",
									"text": " in Saint Paul, Minnesota, and is now the director of the "
								},
								{
									"_type": "span",
									"_key": "key-23-x1exa",
									"text": "Rose O’Neill Literary House",
									"marks": [
										"key-22-vp86n"
									]
								},
								{
									"_type": "span",
									"_key": "key-24-88e53",
									"text": " and Associate Professor of English at "
								},
								{
									"_type": "span",
									"_key": "key-26-6qr4p",
									"text": "Washington College",
									"marks": [
										"key-25-91yey"
									]
								},
								{
									"_type": "span",
									"_key": "key-27-95noi",
									"text": " in Chestertown, Maryland. Mark has written three books of poetry, all published by Coffee House Press: "
								},
								{
									"_type": "span",
									"_key": "key-29-qu76m",
									"text": "Revenants",
									"marks": [
										"em",
										"key-28-gxjse"
									]
								},
								{
									"_type": "span",
									"_key": "key-30-9qoni",
									"text": " (2000), "
								},
								{
									"_type": "span",
									"_key": "key-32-2bri5",
									"text": "Shut Up Shut Down",
									"marks": [
										"em",
										"key-31-rk5e3"
									]
								},
								{
									"_type": "span",
									"_key": "key-33-qk4ko",
									"text": " (2004), and "
								},
								{
									"_type": "span",
									"_key": "key-35-zc66s",
									"text": "Coal Mountain Elementary",
									"marks": [
										"em",
										"key-34-bpcfh"
									]
								},
								{
									"_type": "span",
									"_key": "key-36-12gsr",
									"text": " (2009) and edited Theodore Enslin’s "
								},
								{
									"_type": "span",
									"_key": "key-38-qq1xn",
									"text": "Then and Now: Selected Poems 1943-1993",
									"marks": [
										"em",
										"key-37-de06a"
									]
								},
								{
									"_type": "span",
									"_key": "key-39-xhik5",
									"text": " (National Poetry Foundation, 1999) and co-edited, with Diane Glancy, the anthology "
								},
								{
									"_type": "span",
									"_key": "key-41-2h2zv",
									"text": "Visit Teepee Town: Native Writings After the Detours",
									"marks": [
										"em",
										"key-40-qgr1u"
									]
								},
								{
									"_type": "span",
									"_key": "key-42-j7ne1",
									"text": " (Coffee House, 1999). Mark's essays and critical writings have been published in "
								},
								{
									"_type": "span",
									"_key": "key-43-jy7xg",
									"text": "The Progressive",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-44-yyh7r",
									"text": ", "
								},
								{
									"_type": "span",
									"_key": "key-45-vwcjh",
									"text": "Virginia Quarterly Review",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-46-w3vod",
									"text": ", and "
								},
								{
									"_type": "span",
									"_key": "key-48-q1e2f",
									"text": "Goth: Undead Subculture",
									"marks": [
										"em",
										"key-47-gzhwx"
									]
								},
								{
									"_type": "span",
									"_key": "key-49-zbd4f",
									"text": " (Duke UP, 2007). Mark is the founding editor of the journal "
								},
								{
									"_type": "span",
									"_key": "key-51-gqnlg",
									"text": "XCP: Cross Cultural Poetics",
									"marks": [
										"key-50-8w93f"
									]
								},
								{
									"_type": "span",
									"_key": "key-52-g62ov",
									"text": " and has been active on the web as both a contributor to the Poetry Foundation’s "
								},
								{
									"_type": "span",
									"_key": "key-54-sfe0t",
									"text": "Harriet Blog",
									"marks": [
										"key-53-t50kq"
									]
								},
								{
									"_type": "span",
									"_key": "key-55-opjal",
									"text": " and as the operator of the "
								},
								{
									"_type": "span",
									"_key": "key-57-euv4k",
									"text": "Coal Mountain",
									"marks": [
										"key-56-0iwop"
									]
								},
								{
									"_type": "span",
									"_key": "key-58-7w4ts",
									"text": " blog, which serves as an international clearinghouse for news about labor and safety conditions in resource extraction industries around the world. In recent years Nowak has facilitated a series of “poetry dialogues” between Ford autoworkers at plants in St. Paul, Minnesota, and Port Elizabeth and Pretoria, South Africa. His work in South Africa has led him to edit a special "
								},
								{
									"_type": "span",
									"_key": "key-60-adqj2",
									"text": "double issue",
									"marks": [
										"key-59-krug3"
									]
								},
								{
									"_type": "span",
									"_key": "key-61-ajzqc",
									"text": " of "
								},
								{
									"_type": "span",
									"_key": "key-62-xe0s0",
									"text": "XCP",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-63-u81si",
									"text": " on South African literature and social movements as well as a section on late-apartheid worker poets in a forthcoming anthology from Wesleyan University Press.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-64-zozp2",
									"text": "As I explain in the "
								},
								{
									"_type": "span",
									"_key": "key-65-yncq2",
									"text": "Contemporary Literature",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-66-9nkop",
									"text": ", I first read Mark's work quite by accident, while I was browsing through Claudia Rankine and Lisa Sewell's  "
								},
								{
									"_type": "span",
									"_key": "key-67-4akgg",
									"text": "American Poets in the 21st Century: The New Poetics ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-68-5hlhj",
									"text": "in the library. I saw his work (excerpted from "
								},
								{
									"_type": "span",
									"_key": "key-69-knubf",
									"text": "Shut Up, Shut Down",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-70-zmt4d",
									"text": ") and was both fascinated and really impressed. I wanted to read more of his work, which I did, and once I had I wanted to meet him. Fortunately, I had been asked not long before that to co-curate the "
								},
								{
									"_type": "span",
									"_key": "key-72-ss2hi",
									"text": "FELIX reading series",
									"marks": [
										"key-71-ei907"
									]
								},
								{
									"_type": "span",
									"_key": "key-73-w6lom",
									"text": " by my friend Hai-Dang, and in our next meeting, I expressed interest in bringing Mark to read for our series. Hai was similarly enthusiastic, and Mark came to read for FELIX along with another poet/scholar I admire a great deal, "
								},
								{
									"_type": "span",
									"_key": "key-75-kyjg2",
									"text": "Philip Metres",
									"marks": [
										"key-74-sxedm"
									]
								},
								{
									"_type": "span",
									"_key": "key-76-k4lo5",
									"text": ".\n\n"
								},
								{
									"_type": "span",
									"_key": "key-77-oy72u",
									"text": "[caption id=\"attachment_138\" align=\"alignright\" width=\"500\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-13-7n1it",
									"href": "http://steelwagstaff.files.wordpress.com/2011/05/nowak_interview.pdf"
								},
