			{
				"id": "posts:reading-recommendations-friends-september-2016",
				"slug": "reading-recommendations-friends-september-2016",
				"status": "published",
				"data": {
					"title": "Reading Recommendations from Friends [September 2016]",
					"featured_image": {
						"provider": "external",
						"id": "",
						"src": "https://steelwagstaff.info/wordpress/wp-content/uploads/2016/09/7318346230_e81850a5a6_k-1.jpg"
					},
					"content": [
						{
							"_type": "block",
							"_key": "key-2-wq0mf",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-xuy62",
									"text": "I've been on a reading kick lately and I decided to crowdsource some recommendations to some friends on social media earlier this week. The question I posed was simple: \"Knowing me as you do, what would you recommend I read next? One rule: no fiction, unless it's life changing or the best thing you've ever read.\" I got all kinds of great suggestions, so I thought I'd put a semi-permanent post up here to keep track of them all, and to have a place for interested friends from the thread to see all of them in one place."
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-4-cbird",
							"style": "h3",
							"children": [
								{
									"_type": "span",
									"_key": "key-3-wbb98",
									"text": "Reading Recommendations from Friends"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-138-p3ofy",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-5-grjtd",
									"text": "Here's the list of suggestions I got from friends (last names removed for privacy):\n\n"
								},
								{
									"_type": "span",
									"_key": "key-6-xufms",
									"text": "Charly",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-7-vmfo5",
									"text": ": "
								},
								{
									"_type": "span",
									"_key": "key-9-bfzxi",
									"text": "Social",
									"marks": [
										"key-8-rg8bw",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-10-apvge",
									"text": " by Matthew Lieberman was accessible but not dumbed down. Breakthroughs in social neuroscience.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-11-uq7nx",
									"text": "Christina:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-12-66qjj",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-14-diuza",
									"text": "Unconditional Parenting",
									"marks": [
										"key-13-e2n1o",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-15-ktdc3",
									"text": " by Alfie Kohn and "
								},
								{
									"_type": "span",
									"_key": "key-17-3shzx",
									"text": "Dumbing Us Down: ",
									"marks": [
										"em",
										"key-16-gvx6b"
									]
								},
								{
									"_type": "span",
									"_key": "key-18-17lb0",
									"text": "The Hidden Curriculum of Compulsory Schooling ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-19-451qv",
									"text": "by John Taylor Gatto [my response:"
								},
								{
									"_type": "span",
									"_key": "key-20-x7gim",
									"text": " The other book I'm excited to read on this topic is Alison Gopnik's brand new book about children and parents, "
								},
								{
									"_type": "span",
									"_key": "key-22-6g5o4",
									"text": "The Gardner and the Carpenter",
									"marks": [
										"key-21-4ukgq",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-23-vbgfs",
									"text": "]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-24-6zg33",
									"text": "Keith:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-25-n78zy",
									"text": " Three I've loved lately: "
								},
								{
									"_type": "span",
									"_key": "key-27-2trve",
									"text": "Tough Trip Through Paradise",
									"marks": [
										"key-26-j52lg",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-28-mp71d",
									"text": " by Andrew Garcia, "
								},
								{
									"_type": "span",
									"_key": "key-30-w1r55",
									"text": "Northern Seas, Hardy Sailors",
									"marks": [
										"key-29-44vur",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-31-7enu5",
									"text": " ",
									"marks": [
										"key-29-44vur"
									]
								},
								{
									"_type": "span",
									"_key": "key-32-isfx5",
									"text": "by George Whitely and "
								},
								{
									"_type": "span",
									"_key": "key-34-w5eq3",
									"text": "Journal of a Trapper",
									"marks": [
										"key-33-02vfv",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-35-pks90",
									"text": " by Osborne Russell. "
								},
								{
									"_type": "span",
									"_key": "key-37-1uydr",
									"text": "Travels in Alaska",
									"marks": [
										"key-36-sfttv",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-38-dzv0u",
									"text": " by John Muir is an all time favorite--good luck!\n\n"
								},
								{
									"_type": "span",
									"_key": "key-39-43rb2",
									"text": "Brendon:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-40-9qd6l",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-42-q2vr4",
									"text": "Smoke Gets in Your Eyes: And Other Lessons from the Crematory",
									"marks": [
										"key-41-cx7y8",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-43-z0rm4",
									"text": " by Caitlin Doughty\n"
								},
								{
									"_type": "span",
									"_key": "key-44-eia7g",
									"text": "Margene",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-45-760va",
									"text": ": OOOH I love this one as well. If you haven't read "
								},
								{
									"_type": "span",
									"_key": "key-47-jdijy",
									"text": "Stiff",
									"marks": [
										"key-46-cag1j",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-48-pi8eo",
									"text": " by Mary Roach you'll like it.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-49-z9dou",
									"text": "Monika:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-50-hlmpf",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-52-8ymin",
									"text": "The Warmth of Other Suns",
									"marks": [
										"key-51-18yz8",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-53-w3k2h",
									"text": " by Isabel Wilkerson was at times shocking, occasionally repetitive, but completely fascinating. "
								},
								{
									"_type": "span",
									"_key": "key-55-2pkk9",
									"text": "When Breath Becomes Air",
									"marks": [
										"key-54-r82rf",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-56-a09sx",
									"text": " by Paul Kalanithi was sad and hopeful. It's a quick read and worth the sadness.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-57-37y2j",
									"text": "Kevin:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-58-3oty0",
									"text": " 1) "
								},
								{
									"_type": "span",
									"_key": "key-60-l79vh",
									"text": "Dreamland: The True Tale of America's Opiate Epidemic",
									"marks": [
										"em",
										"key-59-f4aav"
									]
								},
								{
									"_type": "span",
									"_key": "key-61-sub2d",
									"text": " and 2) "
								},
								{
									"_type": "span",
									"_key": "key-63-8rl59",
									"text": "The Anthropology of Childhood\n",
									"marks": [
										"key-62-8zqww",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-64-ajn46",
									"text": "Alex:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-65-6i4oi",
									"text": " You up for a music biography? Nick Cave: "
								},
								{
									"_type": "span",
									"_key": "key-67-7gtyg",
									"text": "Bad Seed",
									"marks": [
										"key-66-ghpfg",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-68-2t2sm",
									"text": " is just wonderful\n\n"
								},
								{
									"_type": "span",
									"_key": "key-69-v01lj",
									"text": "Jim: ",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-71-ifia4",
									"text": "Evicted: Poverty and Profit in the American City",
									"marks": [
										"key-70-41j6h",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-72-txtm5",
									"text": " by Matthew Desmond. It's a masterpiece, Steel. Outstanding research and insights. It turns the traditional notion that poverty causes homelessness on its head. The author argues and documents quite persuasively that homelessness, especially when forced through eviction, actually causes poverty. I strongly recommend it.\n"
								},
								{
									"_type": "span",
									"_key": "key-73-lweie",
									"text": "Dee",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-74-w7r1d",
									"text": ": That's what I was going to recommend, Steel. "
								},
								{
									"_type": "span",
									"_key": "key-75-rxidq",
									"text": "Eviction",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-76-m4850",
									"text": " is both from the heart and from the head. Brilliant read.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-77-yvpm1",
									"text": "Margene:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-78-fhfd0",
									"text": " I really like "
								},
								{
									"_type": "span",
									"_key": "key-80-eay40",
									"text": "White Trash: The 400-year untold history of class in America",
									"marks": [
										"key-79-jto3t",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-81-joea5",
									"text": "; "
								},
								{
									"_type": "span",
									"_key": "key-83-0lys4",
									"text": "Stoned: Jewelry, Obsession, and how Desire shapes the world",
									"marks": [
										"key-82-irrb2",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-84-404v7",
									"text": "; "
								},
								{
									"_type": "span",
									"_key": "key-86-5ken1",
									"text": "Breasts: A natural and unnatural history",
									"marks": [
										"key-85-pluxn",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-87-nqmma",
									"text": "; "
								},
								{
									"_type": "span",
									"_key": "key-89-vctv7",
									"text": "The Disappearing Spoon",
									"marks": [
										"key-88-kqn7m",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-90-w9clw",
									"text": "; "
								},
								{
									"_type": "span",
									"_key": "key-92-pcouh",
									"text": "Better: A surgeon's notes on performance",
									"marks": [
										"key-91-pirxw",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-93-o9zov",
									"text": ".\n\n"
								},
								{
									"_type": "span",
									"_key": "key-94-0axtt",
									"text": "Justin:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-95-2v7c0",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-97-aqn84",
									"text": "Communal Luxury: The Political Imaginary of the Paris Commune",
									"marks": [
										"key-96-ujcb3",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-98-4z85b",
									"text": ", Kristin Ross. Really cool reassessment of the commune in the light of 2011's uprisings.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-99-9325b",
									"text": "Laura:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-100-91byd",
									"text": " Anand Gopal's "
								},
								{
									"_type": "span",
									"_key": "key-102-n9b5c",
									"text": "No Good Men Among the Living",
									"marks": [
										"key-101-sct93",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-103-a5e5q",
									"text": " stands for me as one of the most devastating, beautiful and important pieces of nonfiction of our time. I've read other extraordinary things lately, but nothing touches it. It is painful to know how illuminating this book is and how few people will read it.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-104-z2186",
									"text": "Lauren:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-105-a19og",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-107-4f2ny",
									"text": "Far From the Tree",
									"marks": [
										"key-106-go2bo",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-108-oge4g",
									"text": " by Andrew Solomon. I love this book, it's amazing and I can't recommend it enough (also a good value at almost 1000 pages!)\n\n"
								},
								{
									"_type": "span",
									"_key": "key-109-uknij",
									"text": "Courtney:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-110-tj6g7",
									"text": " I started reading "
								},
								{
									"_type": "span",
									"_key": "key-112-ao6it",
									"text": "Black Skin, White Masks",
									"marks": [
										"key-111-ohloe",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-113-sswlw",
									"text": " last week and have been wondering where I would find a forum for bragging about that fact since.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-114-0r7q2",
									"text": "Jacquelyn:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-115-nnavn",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-117-p9fgp",
									"text": "H is for Hawk",
									"marks": [
										"key-116-u8xtm",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-118-o5c8a",
									"text": ", by Helen MacDonald. I am enjoying Ed Yong's "
								},
								{
									"_type": "span",
									"_key": "key-120-h1r3m",
									"text": "I Contain Multitudes",
									"marks": [
										"key-119-qppsp",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-121-vbet6",
									"text": " right now.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-122-cisyc",
									"text": "Beth:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-123-lrb67",
									"text": " "
								},
								{
									"_type": "span",
									"_key": "key-125-1msoo",
									"text": "Rosemary: The Hidden Kennedy Daughter",
									"marks": [
										"key-124-5lj3y",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-126-yryol",
									"text": ". And... "
								},
								{
									"_type": "span",
									"_key": "key-128-hj7uu",
									"text": "Voluntary Madness: Lost and Found in the Mental Healthcare System",
									"marks": [
										"key-127-f4a94",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-129-2a4un",
									"text": ". Excellent reads.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-130-l0o4f",
									"text": "Sarah:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-131-8z6lj",
									"text": " Reread "
