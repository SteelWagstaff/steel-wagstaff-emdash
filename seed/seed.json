							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-257-g78aw",
									"text": "A Speck in the Sea",
									"marks": [
										"key-256-a9rf7",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-258-zkpgl",
									"text": " by PAUL TOUGH",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-259-jupnx",
									"text": "Looking back, John Aldridge knew it was a stupid move. When you’re alone on the deck of a lobster boat in the middle of the night, 40 miles off the tip of Long Island, you don’t take chances.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
