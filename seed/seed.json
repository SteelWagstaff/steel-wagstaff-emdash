							"children": [
								{
									"_type": "span",
									"_key": "key-186-11ami",
									"text": " In this rare, never before seen, behind-the-scenes shot, you can observe Mixmaster Michael Sherk as he carefully curates those very tunes which were later to blow our minds and free our booties.[/caption]\n"
								},
