					]
				}
			},
			{
				"id": "posts:my-summer-reading",
				"slug": "my-summer-reading",
				"status": "published",
				"data": {
					"title": "My Summer Reading",
					"featured_image": {
						"provider": "external",
						"id": "",
						"src": "https://steelwagstaff.info/wordpress/wp-content/uploads/2017/10/steve-halama-133032.jpg"
					},
					"content": [
						{
							"_type": "block",
							"_key": "key-2-9kthr",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-1voje",
									"text": "I haven't kept up as regularly with these monthly updates as I had hoped, but I did keep reading through the summer. I stayed really plugged into my dissertation reading and research, which really cut down my leisure reading, but I still managed to get through several books that struck my fancy in some way or another."
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-4-bynab",
							"style": "h2",
							"children": [
								{
									"_type": "span",
									"_key": "key-3-4qj3c",
									"text": "Books"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-11-n8jnr",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-5-i291o",
									"text": "William Langewiesche's "
								},
								{
									"_type": "span",
									"_key": "key-7-6piac",
									"text": "Inside the Sky: A Meditation on Flight",
									"marks": [
										"em",
										"key-6-83t04"
									]
								},
								{
									"_type": "span",
									"_key": "key-8-01kfp",
									"text": ". Saw it at a library book sale, and thought I'd give it a try. I've always enjoyed Langewiesche's writing in "
								},
								{
									"_type": "span",
									"_key": "key-9-knmbi",
									"text": "Vanity Fair ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-10-zb92p",
									"text": "and other longform venues, and my father was a navigator in the US Air Force, so I figured I ought to be at least somewhat interested in the topic. A quick but satisfying read."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-6-83t04",
									"href": "http://www.nytimes.com/books/98/06/28/reviews/980628.28gainest.html",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-18-l1lg1",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-12-52oib",
									"text": "Richard Rothstein's "
								},
								{
									"_type": "span",
									"_key": "key-14-re6ge",
									"text": "The Color of Law",
									"marks": [
										"key-13-xl27l",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-15-566cx",
									"text": ". The best nonfiction book I've read all year. Outstanding look at "
								},
								{
									"_type": "span",
									"_key": "key-16-btut0",
									"text": "de jure",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-17-x8pjd",
									"text": " residential segregation in the United States."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-13-xl27l",
									"href": "http://www.epi.org/publication/the-color-of-law-a-forgotten-history-of-how-our-government-segregated-america/",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-23-tusqs",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-19-m2bxh",
									"text": "Simon Reid-Henry's "
								},
								{
									"_type": "span",
