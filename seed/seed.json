								}
							]
						},
						{
							"_type": "block",
							"_key": "key-176-fcvin",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-173-swbcr",
									"text": "The Secret Library of Hope | The Nation",
									"marks": [
										"key-172-t1rao",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-174-vnrcl",
									"text": " by Rebecca Solnit",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-175-0rlze",
									"text": "Hope is an orientation, a way of scanning the wall for cracks--or building ladders--rather than staring at its obdurate expanse.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
