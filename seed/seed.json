							"children": [
								{
									"_type": "span",
									"_key": "key-37-eds1p",
									"text": "Alysia Foster",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-38-htqzs",
									"text": " (American Falls): Works "
								},
								{
									"_type": "span",
									"_key": "key-39-3dopo",
									"text": "for AT&T as a retail sales manager. "
								},
								{
									"_type": "span",
									"_key": "key-40-knj6u",
									"text": "Lives in Boulder, Colorado. Married. Husband earning master's degree in Chinese literature at UC. Two kids. Just became a homeowner!"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-43-cyz48",
