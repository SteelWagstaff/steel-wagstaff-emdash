										"key-22-gfpyi"
									]
								},
								{
									"_type": "span",
									"_key": "key-24-3bd1b",
									"text": ".\n\n"
								},
								{
									"_type": "span",
									"_key": "key-25-als52",
									"text": "[caption id=\"attachment_919\" align=\"alignleft\" width=\"500\"]"
								}
