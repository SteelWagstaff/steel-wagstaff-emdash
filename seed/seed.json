						{
							"_type": "block",
							"_key": "key-79-u9nq3",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-72-1brqg",
									"text": "Colin Ward's "
								},
								{
									"_type": "span",
									"_key": "key-74-sx9xf",
									"text": "Anarchism",
									"marks": [
										"key-73-5177t",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-75-arb1g",
									"text": ". I loved Colin Ward as a personality and as a writer when he was alive and have always been deeply sympathetic to philosophical anarchism. And it increasingly appears that, in the coming Trump era, "
								},
								{
									"_type": "span",
									"_key": "key-77-hmgj3",
									"text": "I'm not alone",
									"marks": [
										"key-76-afhif"
									]
								},
								{
									"_type": "span",
									"_key": "key-78-8kc44",
									"text": "."
								}
							],
							"markDefs": [
