						{
							"_type": "block",
							"_key": "key-47-fm8w3",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-44-5x2ht",
									"text": "On Friendship",
									"marks": [
										"key-43-5sgrq",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-45-ma7kx",
									"text": " by Edward Hoagland",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-46-sncl9",
									"text": "“Let’s just be friends,” lovers proverbially say when breaking up, even if their empathy is shredding and they mainly mean to try not to sabotage each other by blabbing their secrets wholesale.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
