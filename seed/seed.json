									"_type": "span",
									"_key": "key-50-kjsd9",
									"text": " (Grangeville): Now Jessie Hackford. W"
								},
								{
									"_type": "span",
									"_key": "key-51-oxg7o",
									"text": "ent to Westminster College in Utah. Married her college sweetheart. He's a computer guy, she's an editor. Two kids and a cat. "
								}
