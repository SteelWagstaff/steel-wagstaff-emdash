							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-57-rqwxp",
									"text": "Ian Shaw's "
								},
								{
									"_type": "span",
									"_key": "key-59-92y89",
									"text": "Ancient Egypt",
									"marks": [
										"key-58-a4n93",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-60-31yhy",
									"text": ". Covered a lot of ground, but spread itself a bit too thin, I thought."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-58-a4n93",
									"href": "https://global.oup.com/academic/product/ancient-egypt-a-very-short-introduction-9780192854193?q=ancient%20egypt%20shaw&lang=en&cc=us",
