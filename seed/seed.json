									"_key": "key-149-dw36u",
									"text": ",\" Yasmine Seale writing about visual representations of the steed upon which Muhammad made his night journey to heaven in "
								},
								{
									"_type": "span",
									"_key": "key-150-6ywtl",
									"text": "The Public Domain Review",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-151-lbmxm",
									"text": ". Some incredible images here."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-147-ap3bo",
