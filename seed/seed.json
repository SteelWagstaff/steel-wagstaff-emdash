										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-94-ib0ut",
									"text": " by JENNIFER STEINHAUER",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-95-6jqcw",
									"text": "WASHINGTON — It was, Senator Harry Reid of Nevada ebulliently proclaimed, a “happy day for me” as he stood with Wayne LaPierre, the head of the National Rifle Association, in 2010 at a new shooting range in Las Vegas made possible by federal money secured by Mr. Reid.",
									"marks": [
