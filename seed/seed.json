									"_type": "link",
									"_key": "key-127-s16jw",
									"href": "http://www.nytimes.com/2013/05/05/magazine/y-combinator-silicon-valleys-start-up-machine.html?nl=todaysheadlines&emc=edit_th_20130503&pagewanted=all"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-136-ktdt6",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-133-22lnr",
									"text": "The Quarrels of Others: On Anti-Semitism | The Nation",
									"marks": [
										"key-132-8hyie",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-134-34dpp",
									"text": " by David Nirenberg.",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-135-hueti",
									"text": "With Anti-Judaism, David Nirenberg has recast the debate about the origins and nature of anti-Semitism in Western thought.  “In sooth, I know not why I am so sad,” Antonio wonders at the outset of The Merchant of Venice.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
