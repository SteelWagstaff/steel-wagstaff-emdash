									"_key": "key-100-swiha",
									"text": "a Guardian article",
									"marks": [
										"key-99-jydnd"
									]
								},
								{
									"_type": "span",
									"_key": "key-101-kg1xo",
									"text": " on the eccentric resourcefulness of Grimsby (a place I lived for 3 months) fans; and Johnny McDevitt's "
								},
								{
									"_type": "span",
									"_key": "key-103-v6yiu",
									"text": "Guardian feature on Jaber Abdullah",
									"marks": [
										"key-102-pf6a4"
									]
								},
								{
									"_type": "span",
									"_key": "key-104-dqign",
									"text": ", a Sudanese asylum seeker who has created a football team for refugees in Barnsley (the last town I lived in before returning to the United States)."
								}
							],
							"markDefs": [
