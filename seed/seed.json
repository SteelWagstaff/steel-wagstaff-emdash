								}
							]
						},
						{
							"_type": "block",
							"_key": "key-21-shyy5",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-18-4ymvw",
									"text": "Stoicism",
									"marks": [
										"em",
										"key-17-p65hm"
									]
								},
								{
									"_type": "span",
									"_key": "key-19-0qrtu",
									"text": " ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-20-m5za6",
									"text": "by John Sellars. A brief introduction to the philosophical thought of the ancient Greek Stoics. Turned me on to Epictetus, which was a fortunate encounter."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-17-p65hm",
									"href": "http://www.ucpress.edu/book.php?isbn=9780520249080",
									"blank": true
