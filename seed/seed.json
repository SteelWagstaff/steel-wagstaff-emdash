									"_type": "link",
									"_key": "key-261-ssjnq",
									"href": "http://www.newyorker.com/humor/2014/01/13/140113sh_shouts_hodgman?utm_source=tny&utm_campaign=generalsocial&utm_medium=facebook"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-269-6r0oe",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-266-ja3qh",
									"text": "Editing Your Life's Stories Can Create Happier Endings",
									"marks": [
										"key-265-61j1c",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-267-41u4i",
									"text": " by Tim Wilson",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-268-r5tpd",
									"text": "It was a rainy night in October when my nephew Lewis passed the Frankenstein statue standing in front of a toy store. The 2 1/2-year-old boy didn't see the monster at first, and when he turned around, he was only inches from Frankenstein's green face, bloodshot eyes and stitched-up skin.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
