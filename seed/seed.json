									"blank": true
								},
								{
									"_type": "link",
									"_key": "key-62-i0aw0",
									"href": "https://www.rogueamoeba.com/loopback/buy.php",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-78-jcyz4",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-67-hnu9d",
									"text": "Audacity",
									"marks": [
										"key-66-cttqj"
									]
								},
								{
									"_type": "span",
									"_key": "key-68-hip4d",
									"text": " (you can use "
								},
								{
									"_type": "span",
									"_key": "key-70-nh1la",
									"text": "GarageBand",
									"marks": [
										"key-69-ip65w"
									]
								},
								{
									"_type": "span",
									"_key": "key-71-u9aem",
									"text": " if you’d rather, but I was trained on Audacity, and like it because it’s open source). This is the program that I use to record and edit the audio. You’ll also likely want to download an mp3 encoder, which you’ll need if you want to export your audacity files to the .mp3 format. [encoder for "
								},
								{
									"_type": "span",
									"_key": "key-73-xa980",
									"text": "mac",
									"marks": [
										"key-72-dazil"
									]
								},
								{
									"_type": "span",
									"_key": "key-74-mvlwi",
									"text": " | encoder for "
								},
								{
									"_type": "span",
									"_key": "key-76-skc74",
									"text": "Windows",
									"marks": [
										"key-75-qx3dx"
									]
								},
								{
									"_type": "span",
									"_key": "key-77-inmgb",
									"text": "]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-66-cttqj",
									"href": "http://sourceforge.net/projects/audacity/",
									"blank": true
								},
