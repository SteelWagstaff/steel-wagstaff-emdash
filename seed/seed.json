								},
								{
									"_type": "span",
									"_key": "key-21-rv7k1",
									"text": "For the front of the postcard, I used a photograph taken in the fall of last year by our friend "
								},
								{
									"_type": "span",
									"_key": "key-23-bzz1e",
									"text": "Sam Crowfoot",
