									"_type": "link",
									"_key": "key-171-x8lz9",
									"href": "http://www.goodmancenter.org/services/working-class-catering"
								},
								{
									"_type": "link",
									"_key": "key-175-u0cea",
									"href": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-594.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-177-92n98",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-594.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-594.jpg"
							},
							"alt": ""
						},
						{
							"_type": "block",
							"_key": "key-184-56ckf",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-178-p1ce0",
									"text": " Laurel and I laugh as Jennie toasts (or perhaps roasts?) us.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-179-oxsxe",
									"text": "After the toasts, we brought out the cupcakes (from our wonderfully talented neighbor Gale Shu--more on those in a later post) and then moved onto the dance floor, all tunes provided by the inimitable Mike Sherk of "
								},
								{
									"_type": "span",
									"_key": "key-181-lmook",
									"text": "Mandarin Dynasty",
									"marks": [
										"key-180-mcwfv"
									]
								},
								{
									"_type": "span",
									"_key": "key-182-u94r6",
									"text": " fame. [caption id=\"attachment_882\" align=\"alignleft\" width=\"500\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
