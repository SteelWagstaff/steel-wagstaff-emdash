									"text": "'Inverted Jenny' Stamp On Auction Block",
									"marks": [
										"key-137-fsusp",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-139-pfz36",
									"text": " ",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
