			{
				"id": "posts:night-scene-by-george-oppen-2",
				"slug": "night-scene-by-george-oppen-2",
				"status": "published",
				"data": {
					"title": "\"Night Scene\" by George Oppen",
					"content": [
						{
							"_type": "block",
							"_key": "key-15-wgmuj",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-zqu7e",
									"text": "The drunken man\n"
								},
								{
									"_type": "span",
									"_key": "key-2-d6qec",
									"text": "On an old pier\n"
								},
								{
									"_type": "span",
									"_key": "key-3-qyzyr",
									"text": "In the Hudson River\n\n"
								},
								{
									"_type": "span",
									"_key": "key-4-h3oza",
									"text": "Tightening his throat, thrust his chin\n"
								},
								{
									"_type": "span",
									"_key": "key-5-9ne9p",
									"text": "Forward and the light\n"
								},
								{
									"_type": "span",
									"_key": "key-6-89483",
									"text": "Caught his face\n"
								},
								{
									"_type": "span",
									"_key": "key-7-fkecd",
									"text": "His eyes still blind with drink\n\n"
								},
								{
									"_type": "span",
									"_key": "key-8-bvr8g",
									"text": "Said, to my wife\n"
								},
								{
									"_type": "span",
									"_key": "key-9-rmngp",
									"text": "And to me —\n"
								},
								{
									"_type": "span",
									"_key": "key-10-x55hr",
									"text": "He must have been saying\n\n"
								},
								{
									"_type": "span",
									"_key": "key-11-h2526",
									"text": "Again —\n\n"
								},
								{
									"_type": "span",
									"_key": "key-12-wp97i",
									"text": "Good bye Momma\n"
								},
								{
									"_type": "span",
									"_key": "key-13-kafco",
									"text": "Good bye Poppa\n\n"
								},
								{
									"_type": "span",
									"_key": "key-14-xm1n2",
									"text": "On an old pier"
								}
							]
						}
					]
				}
			},
