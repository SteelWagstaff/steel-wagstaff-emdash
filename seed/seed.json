							},
							"alt": ""
						},
						{
							"_type": "block",
							"_key": "key-150-9h0uk",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-146-1qp6e",
									"text": " What a finished table looked like before the floral centerpiece was added[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-147-ylpcq",
									"text": "Laurel bought the flowers from a local grower in Milwaukee--largely tulips, daffodils, and narcissus--and arranged them beautifully, with a center piece at each table. More on this in a later post on decorations.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-148-t5tx7",
									"text": "[caption id=\"attachment_846\" align=\"alignleft\" width=\"500\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-149-ym8am",
									"href": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-428.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-151-sdxtp",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-428.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-428.jpg"
							},
							"alt": ""
						},
						{
							"_type": "block",
