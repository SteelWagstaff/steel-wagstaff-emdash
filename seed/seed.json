						},
						{
							"_type": "block",
							"_key": "key-72-8i35c",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-69-4xkgd",
									"text": "Autism Inc.: The Discredited Science, Shady Treatments and Rising Profits Behind Alternative Autism Treatments",
									"marks": [
										"key-68-egfem",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-70-haad9",
									"text": " by Alex Hannaford",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-71-uxj96",
									"text": "The lowest point for Ann Dimick came in January 2012, when in the middle of the night she climbed out of bed, walked across her bedroom and into the closet, closed the door, sat cross-legged on the floor, and dissolved into tears.",
									"marks": [
										"strong"
									]
								}
