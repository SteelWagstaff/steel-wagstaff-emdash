			{
				"id": "posts:handwritten-note-on-lorine-niedecker",
				"slug": "handwritten-note-on-lorine-niedecker",
				"status": "published",
				"data": {
					"title": "Handwritten note on Lorine Niedecker",
					"content": [
						{
							"_type": "block",
							"_key": "key-3-unkhe",
							"style": "blockquote",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-1iabb",
									"text": "Lorine Niedecker\n\n"
								},
								{
									"_type": "span",
									"_key": "key-2-njcd0",
									"text": "Visited her in March (1970)—rumors: total recluse — something wrong with her? Mental breakdown?—ordinary cleaning woman in mental hospital—so, trepidation—fears groundless / “moment I walked in her door, she was opposite of recluse: outgoing, of good cheer, very lively. Time flew. Delightful afternoon—much in common with Al. —House only a few steps from water, ground-level (no basement or steps) so small, if three of us had called on her instead of two, we cdn’t have moved past each other"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-5-d4nds",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-4-3z9t3",
									"text": "-- from Carl Rakosi's manuscript collection at UC-San Diego."
								}
							]
						}
					]
				}
