			{
				"id": "music:50-tracks-best-of-may-2013",
				"slug": "50-tracks-best-of-may-2013",
				"status": "published",
				"data": {
					"title": "50 Tracks [Best of May 2013]",
					"featured_image": {
						"id": "",
						"provider": "external",
						"src": "https://steelwagstaff.info/wordpress/wp-content/uploads/2016/11/leaf_hand-e1389368408552.jpg"
					},
					"content": [
						{
							"_type": "block",
							"_key": "k1",
							"style": "normal",
							"markDefs": [],
							"children": [
								{
									"_type": "span",
									"_key": "k0",
									"text": "April had 100 tracks, and May had but 50. More time out of doors, perhaps? All the same, there are some lovelies in here. Fair amount of Bob Dylan, Sharon Van Etten, and Penguin Cafe Orchestra. Enjoy.",
									"marks": []
								}
							]
						},
						{
							"_type": "block",
							"_key": "k3",
							"style": "normal",
							"markDefs": [],
							"children": [
