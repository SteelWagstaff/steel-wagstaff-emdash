									"href": "http://www.youtube.com/watch?v=winiZ1TZd8E"
								},
								{
									"_type": "link",
									"_key": "key-30-i0dph",
									"href": "http://www.flickr.com/photos/andy3139/417399520/"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-32-25o3m",
							"asset": {
								"_type": "reference",
								"_ref": "http://farm1.staticflickr.com/148/417399520_985263a803.jpg",
								"url": "http://farm1.staticflickr.com/148/417399520_985263a803.jpg"
							},
							"alt": "Grimethorpe Colliery 2000"
						},
						{
							"_type": "block",
							"_key": "key-43-0o0e1",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-33-6wb0x",
									"text": " Grimethorpe Colliery, 2000. Photo taken by Andy Bailey.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-34-zksyj",
									"text": "I didn’t know it at the time, but Grimethorpe was infamous. Its "
								},
								{
									"_type": "span",
									"_key": "key-36-cjmm8",
									"text": "colliery brass band",
									"marks": [
										"key-35-u4ra1"
									]
								},
								{
									"_type": "span",
									"_key": "key-37-sw9n1",
									"text": " inspired the 1996 film "
								},
								{
									"_type": "span",
									"_key": "key-39-zkoko",
									"text": "Brassed Off",
									"marks": [
										"key-38-c89b3",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-40-vk0re",
									"text": ", with Pete Postlethwaite & Ewan McGregor, but it was best known as one of the poorest and most deprived communities in all of Western Europe, with an unemployment rate that had hovered around 50% for much of the past decade.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-41-k6sch",
									"text": "[caption id=\"\" align=\"alignnone\" width=\"800\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-35-u4ra1",
									"href": "http://grimethorpeband.com/"
								},
								{
									"_type": "link",
									"_key": "key-38-c89b3",
									"href": "http://www.youtube.com/watch?v=C8uoY9e5YVY"
								},
								{
									"_type": "link",
									"_key": "key-42-87418",
									"href": "http://www.flickr.com/photos/65786329@N07/7321304004/"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-44-kxlvp",
							"asset": {
								"_type": "reference",
								"_ref": "http://farm8.staticflickr.com/7100/7321304004_7b5c152e00_c.jpg",
								"url": "http://farm8.staticflickr.com/7100/7321304004_7b5c152e00_c.jpg"
							},
							"alt": "Grimethorpe"
						},
						{
							"_type": "block",
							"_key": "key-50-wq29b",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-45-ysvb8",
									"text": " Grimethorpe Brass Band, 2012. Photo by David Geilby.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-46-oky6p",
									"text": "Before we stopped at Anne’s address we spent some time knocking on doors in the village and stopping passersby in the streets, as was our practice. Most people were dismissive, as was their practice, but we got invited in to one home, I think, because it was raining heavily and they could tell by our accents that we were Yanks (which made a curiosity in a small provincial village like Grimethorpe). The people we spoke with talked about the crippling depression they felt to find themselves without work despite having two willing hands and a lifetime spent in the same occupation, of the despair they felt watching their community crumble and disintegrate, of their rage and frustration at being without work and without prospects for work, and of their feelings of betrayal at decisions made far from them and without their consent.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-47-2u1s8",
									"text": "When we finally got up to Anne Tyson’s street, it was mid-afternoon. We turned up Carlton Street and took a deep breath. It was in the middle of council estate, and it looked like total chaos. It was a long street of brick rowhouses, about 1/3 of which had their windows boarded up. Wild looking children were playing with a couple of dogs near the top of the street. One of them, a nasty looking bulldog, prattled past us, and I could literally see its skin bristle with fleas. The street was noisy, with several of the unboarded doors left open, with people drinking on the stoops. As we walked up the street we saw about half a dozen people running up and down the road and leaning out of upstairs windows in various states of undress, shouting profane things at each other and us. The kind of street we faced daily, but always dreaded, no matter how brave or openhearted we felt.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-48-zx8pf",
									"text": "[caption id=\"attachment_1331\" align=\"alignnone\" width=\"500\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-49-kruwu",
									"href": "http://steelwagstaff.files.wordpress.com/2012/10/carlton_street.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-51-bdeb9",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/10/carlton_street.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/10/carlton_street.jpg"
							},
							"alt": ""
						},
						{
							"_type": "block",
							"_key": "key-69-0gj5v",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-52-d8ve8",
									"text": " Google Image street view of Carlton Street (just a few doors down from where Anne Tyson lived in 2003). This photo taken in 2009. The street looked much healthier--it seems Grimethorpe is healing.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-53-srfov",
									"text": "We knocked on the door at 34 Carlton St. It was answered by a youngish woman with peroxide bleached hair wearing a green tank top with a couple of dark, greasy looking stains. We introduced ourselves in the usual way and asked if she was Anne.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-54-smf9o",
									"text": "“No,” she said, “I’m Melissa—well, Mel, axshly. Anne’s me mum.”\n\n"
								},
								{
									"_type": "span",
									"_key": "key-55-ae9wr",
									"text": "Is she in, we asked? \"Yeah,\" she said, \"she’s juss inside.\" May we come in then, and deliver the film she ordered?\n\n"
								},
								{
									"_type": "span",
									"_key": "key-56-7hxaw",
									"text": "“Lemme see,” she said, and turned her head and shouted over shoulder: “Maaaa, there’s some JoVo’s what’s here to give ya some Jesus thing. You wanna talk to ‘em?”\n\n"
								},
								{
									"_type": "span",
									"_key": "key-57-0oyjd",
									"text": "We didn’t hear a response, but Mel looked back at us, and said \"A’right, you can come in.\"\n\n"
								},
								{
									"_type": "span",
									"_key": "key-58-9isxd",
									"text": "Now the rules for us were that we had to have another male present (over the age of 12, I think) anytime we entered into a single woman’s home, or married women, or any women, really. So just before we step over the threshold I had to ask awkwardly, whether there’s a man in the home, explaining that I'm asking because it’s part of the rules that we have to live by as missionaries.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-59-97vip",
									"text": "“I dunno about a man,” Mel says, “but my bairn Ashley’s just outside.” She leaned past us, putting her head into the street and shouted, as big as you like, “Ash-ley! Ger’ in here. I need you for sum-itt.”\n\n"
								},
								{
									"_type": "span",
									"_key": "key-60-9e2yf",
									"text": "Hearing Mel shout, a man a few houses down grabbed his crotch and hollered back, \"Oy--Mel! I've got sum-itt for ya!\" And several of the people drinking with him whistled and mocked and laughed. A few seconds later two kids appeared in the doorway next to us. One looked to be in his early teens, and the other must have been about 7 or 8. I hoped the bigger one was Ashley. “Ger’ inside Ashley,” Melissa said. “Keel, I’m not bovvered ‘bout you. These JoVo’s’re here to preach about God. You can do what you like.”\n\n"
								},
								{
									"_type": "span",
									"_key": "key-61-ohvaz",
									"text": "The bigger kid bowed his head and vanished out of sight behind her into the living room. I felt relieved. Keel didn’t respond to Mel, but stood there on the doorstep for a couple of seconds staring hard at us. “Are you from ‘Merica?” he asked.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-62-ognkj",
									"text": "“Yeah,” I said. “How 'bout you?”\n\n"
								},
								{
									"_type": "span",
									"_key": "key-63-fk3zt",
									"text": "“No. I’m from Grimethorpe, me.” Deadpan. He slipped past Mel into the living room. Mel looked at us both and turned back inside. “Well, you comin’ in or wot?”\n\n"
								},
								{
									"_type": "span",
									"_key": "key-64-we0bf",
									"text": "We stepped over the threshold into Anne Tyson’s living room. The room was dark and thick with cigarette smoke so it took a few seconds for me to take in all the surroundings. Anne was a big woman, seated on an filthy old floral print couch that looked like it was made of slick velvet. It had dark discolorations all over it. She motioned for us to sit down. The only sound in the room was a deep wheezing that came from Anne’s respirator, a big silver oxygen tank just beside her at the far end of the couch, with tubes running to strategic places in her body. She was smoking, and had two 3-liter plastic bottles of "
								},
								{
									"_type": "span",
									"_key": "key-66-dmhcy",
									"text": "White Lightning cider",
									"marks": [
										"key-65-jyevx"
									]
								},
								{
									"_type": "span",
									"_key": "key-67-n8e18",
									"text": " at her feet.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-68-5sbop",
									"text": "We came in and taught the family. It was a good discussion, I suppose. Anne was earnest and curious, as I recall. I’m sure that many things were said or done during that conversation, and my journal and weekly records indicate that we returned at least once more to visit with Anne, but I don’t remember any of that. I remember only two things:"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-65-jyevx",
									"href": "http://alcoholresearchuk.org/2012/02/01/white-cider-and-street-drinkers/"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-77-xo35i",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-70-zqv80",
									"text": "Her grandson Ashley was tall for his age, of what the English call ‘mixed race’, and had long, sinewy arms. He had the look of a tremendous baseball pitcher. He was wearing a "
								},
								{
									"_type": "span",
									"_key": "key-72-5wpko",
									"text": "burberry hat",
									"marks": [
										"key-71-fkf0o"
									]
								},
								{
									"_type": "span",
									"_key": "key-73-htx35",
									"text": " and track suit bottoms. No shirt. He took his hat off when we began speaking, perhaps out of respect??? His hair was faintly red. The most striking feature about him, though, were brilliant green eyes, enormous and very earnest. At one point in our conversation he spoke quickly and with surprise about something someone had said, using some profane language. I don’t remember what he said, but I remember the immediate look of shock and embarrassment on his face, and that he looked at us as if he were about to cry and then apologized, unbidden. This was very, very unusual. I was shocked and touched. I felt immediately that he was a singular child, not as hard and cruel as many of the children we met in similar circumstances. I wrote later in my journal about my distinct feelings that he was one of “"
								},
								{
									"_type": "span",
									"_key": "key-75-544f5",
									"text": "the pure in heart",
									"marks": [
										"key-74-9j2lp"
									]
								},
								{
									"_type": "span",
									"_key": "key-76-132ed",
									"text": "” and worried about his future, about his life."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-71-fkf0o",
									"href": "http://www.avenue7.com/MakeThumbnail/400/400/ProductImages/GoodsPickedByShoppers/12942184688812627582740916-40e0-4630-b0b1-bff26b33dca2[D]jpg"
								},
								{
									"_type": "link",
									"_key": "key-74-9j2lp",
									"href": "http://www.biblegateway.com/passage/?search=Matthew%205:1-10&version=KJV"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-79-sk72c",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-78-t9dbd",
									"text": "At one point in our conversation, Anne belched just before she turned to speak to me. It was inadvertent, but she released her breath directly towards me. The smell of her breath in that moment was possibly the foulest thing I have ever smelled, a fetid mix of rot and death, cigarettes and cheap grain alcohol and almost 20 years of a closed colliery and abandoned mines. I nearly vomited and tried to turn away discreetly and catch my breath without being unkind. It is hard to say all the things that I felt (and feel) surrounding that smell, the fragrance, what knowledge it disclosed, what deep wounding it emanated from and transmitted. It was the most powerful smell I have ever experienced, and with the exception of the events surrounding my first marriage and subsequent divorce, probably the saddest moment of my life."
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-83-0uliu",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-80-62ebh",
									"text": "Two weeks later, I was on an airplane flying back across the Atlantic, heading home. My family greeted me at the airport, along with my friend Matt Larson.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-81-ijo5m",
									"text": "[caption id=\"attachment_1350\" align=\"alignnone\" width=\"1024\"]"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-82-6nhpd",
									"href": "http://steelwagstaff.files.wordpress.com/2012/10/with-with-my-family-at-the-airport1.jpg"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-84-p248k",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/10/with-with-my-family-at-the-airport1.jpg?w=1024",
								"url": "http://steelwagstaff.files.wordpress.com/2012/10/with-with-my-family-at-the-airport1.jpg?w=1024"
							},
							"alt": ""
						},
						{
							"_type": "block",
							"_key": "key-87-j1u22",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-85-s8xuc",
									"text": " Photo taken in the Boise airport tunnel, minutes after my family and I saw each other for the first time in nearly two years. Sarah, Camille, Me, Craig, Patti, Bonnie [L-R][/caption]I understand that Mel and Ashley moved to Leeds shortly after I left Barnsley.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-86-kmhdb",
									"text": "I feel quite certain that Anne is dead, and that the video cassette we delivered did not long survive her. And I still cannot think of Grimethorpe without a surge of rage and helplessness in my throat."
								}
							]
						}
					]
				}
			},
			{
				"id": "posts:the-objectivists-carl-rakosi",
				"slug": "the-objectivists-carl-rakosi",
				"status": "published",
				"data": {
					"title": "The Objectivists: Carl Rakosi",
					"content": [
						{
							"_type": "block",
							"_key": "key-3-4nxv7",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-1-0snhy",
									"text": "I've spent the last two weeks getting serious about my dissertation. It's been two years now since I successfully completed my prelim exams, and I have almost nothing to show for that time, dissertation-wise. It's tremendously embarrassing, and even a little painful. By getting serious, I mean that I've been diving into the primary sources for my dissertation project, the poetry of a cluster of really wonderful poets (and people) frequently referred to as \"The Objectivists\": Charles Reznikoff, Louis Zukofsky, George Oppen, Carl Rakosi, Basil Bunting, and Lorine Niedecker. William Carlos Williams was associated with the Objectivists for a time, and many scholars refer to a period of his poetry as \"Objectivist,\" but he is not always considered part of the core group by literary historians.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-2-pnpyi",
									"text": "[caption id=\"attachment_2182\" align=\"alignright\" width=\"793\"]"
								}
							]
						},
						{
							"_type": "image",
							"_key": "key-4-yqii6",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.com/wp-content/uploads/sites/18/2012/08/Rakosi_radio.jpg",
								"url": "http://steelwagstaff.com/wp-content/uploads/sites/18/2012/08/Rakosi_radio.jpg"
							},
							"alt": "Carl Rakosi"
						},
						{
							"_type": "block",
							"_key": "key-11-606wn",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-5-i6q0a",
									"text": "Carl Rakosi, reading his poetry for a 1971 radio broadcast produced by Charles Amirkhanian.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-6-g0new",
									"text": "Reading their writing has energized me considerably, and motivated me to want to both write more of my own poetry and to get working on a dissertation that explores, elucidates, and even champions their impressive poetry. Over the next few weeks, I want to post little samples of the kind of poetry that each of the major Objectivists wrote, so that you too can grow to appreciate and love their work. If you love their poems, please buy the books that their work is contained in--all of the Objectivists except Carl Rakosi have beautiful editions of their collected work published in the past decade, so it is accessible, in print, and there for the enjoyment.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-7-0eo38",
									"text": "To start, here's a small taste of "
								},
								{
									"_type": "span",
									"_key": "key-9-j1bvj",
									"text": "Carl Rakosi",
									"marks": [
										"key-8-d1r03"
									]
								},
								{
									"_type": "span",
									"_key": "key-10-kceu1",
									"text": ", two poems about animals, and two other short lyrics:"
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-8-d1r03",
									"href": "http://www5.uwm.edu/news/2012/07/09/lecturer-donates-materials-on-objectivist-poets-to-uwm-libraries-2/#.UDfLGdZlRqA"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-91-bupst",
							"style": "blockquote",
							"children": [
								{
									"_type": "span",
									"_key": "key-12-w18pl",
									"text": "“No One Talks About This”\n",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-13-r4z6a",
									"text": "They go in different ways.\n"
								},
								{
									"_type": "span",
									"_key": "key-14-qnqb6",
									"text": "One hog is stationed at the far end\n"
								},
								{
									"_type": "span",
									"_key": "key-15-0pf9n",
									"text": "of the pen to decoy the others,\n"
								},
								{
									"_type": "span",
									"_key": "key-16-fy1xv",
									"text": "the hammer knocks the cow\n"
								},
								{
									"_type": "span",
									"_key": "key-17-qi01n",
									"text": "to his knees,\n"
								},
								{
									"_type": "span",
									"_key": "key-18-aemaa",
									"text": "the sheep goes gentle\n"
								},
								{
									"_type": "span",
									"_key": "key-19-soiy4",
									"text": "and unsuspecting.\n"
								},
								{
									"_type": "span",
									"_key": "key-20-54u5p",
									"text": "Then the chain is locked\n"
								},
								{
									"_type": "span",
									"_key": "key-21-zk5z9",
									"text": "around the hind leg\n"
								},
								{
									"_type": "span",
									"_key": "key-22-rdgnh",
									"text": "and the floor descends\n"
								},
								{
									"_type": "span",
									"_key": "key-23-4a68s",
									"text": "from under them.\n"
								},
								{
									"_type": "span",
									"_key": "key-24-z6suy",
									"text": "Head down they hang.\n"
								},
								{
									"_type": "span",
									"_key": "key-25-z8vv6",
									"text": "The great drum turns\n"
								},
								{
									"_type": "span",
									"_key": "key-26-uzvja",
									"text": "the helpless objects\n"
								},
								{
									"_type": "span",
									"_key": "key-27-26tvg",
									"text": "and conveys them slowly\n"
								},
								{
									"_type": "span",
									"_key": "key-28-xpswh",
									"text": "to the butcher waiting\n"
								},
								{
									"_type": "span",
									"_key": "key-29-v61m6",
									"text": "at his station.\n"
								},
								{
									"_type": "span",
									"_key": "key-30-hpy25",
									"text": "The sheep is stabbed\n"
								},
								{
									"_type": "span",
									"_key": "key-31-sszbo",
									"text": "behind the ear.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-32-niuho",
									"text": "Gentle sheep, I am powerless\n"
								},
								{
									"_type": "span",
									"_key": "key-33-alz7d",
									"text": "to mitigate your sorrow.\n"
								},
								{
									"_type": "span",
									"_key": "key-34-i1yl5",
									"text": "Men no longer weep\n"
								},
								{
									"_type": "span",
									"_key": "key-35-xjvnf",
									"text": "by the rivers of Babylon\n"
								},
								{
									"_type": "span",
									"_key": "key-36-jpyzy",
									"text": "but I will speak for you.\n"
								},
								{
									"_type": "span",
									"_key": "key-37-eiqgi",
									"text": "If I forget you, may my eyes\n"
								},
								{
									"_type": "span",
									"_key": "key-38-d6es0",
									"text": "lose their Jerusalem.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-39-oryrb",
									"text": "--from "
								},
								{
									"_type": "span",
									"_key": "key-41-oqhqx",
									"text": "Ere-Voice",
									"marks": [
										"key-40-avjsv",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-42-bw1q1",
									"text": " (1967)\n\n"
								},
								{
									"_type": "span",
									"_key": "key-43-ko4gl",
									"text": "“Poem”\n",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-44-upr0b",
									"text": "The ants came\n"
								},
								{
									"_type": "span",
									"_key": "key-45-clmca",
									"text": "to investigate\n"
								},
								{
									"_type": "span",
									"_key": "key-46-qjtf7",
									"text": "the dead\n"
								},
								{
									"_type": "span",
									"_key": "key-47-sp3m5",
									"text": "bull snake,\n"
								},
								{
									"_type": "span",
									"_key": "key-48-fztu3",
									"text": "nibbled\n"
								},
								{
									"_type": "span",
									"_key": "key-49-d7yux",
									"text": "at the viscera\n"
								},
								{
									"_type": "span",
									"_key": "key-50-287vm",
									"text": "and hurried off\n"
								},
								{
									"_type": "span",
									"_key": "key-51-97lki",
									"text": "with full mouths\n"
								},
								{
									"_type": "span",
									"_key": "key-52-utgjn",
									"text": "waving wild\n"
								},
								{
									"_type": "span",
									"_key": "key-53-ew840",
									"text": "antennae.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-54-rdkfb",
									"text": "Moths alighted,\n"
								},
								{
									"_type": "span",
									"_key": "key-55-5bm0z",
									"text": "beetles swarmed,\n"
								},
								{
									"_type": "span",
									"_key": "key-56-uyw6i",
									"text": "flies buzzed\n"
								},
								{
									"_type": "span",
									"_key": "key-57-wsqwj",
									"text": "in the stomach.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-58-pipn0",
									"text": "Three crows\n"
								},
								{
									"_type": "span",
									"_key": "key-59-r0gbd",
									"text": "tugged and tore\n"
								},
								{
									"_type": "span",
									"_key": "key-60-l5fpl",
									"text": "and flew off\n"
								},
								{
									"_type": "span",
									"_key": "key-61-9wd84",
									"text": "to the oak tree\n"
								},
								{
									"_type": "span",
									"_key": "key-62-a9y42",
									"text": "with the skin.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-63-6sfkc",
									"text": "In every house\n"
								},
								{
									"_type": "span",
									"_key": "key-64-trpdv",
									"text": "men, women and children\n"
								},
								{
									"_type": "span",
									"_key": "key-65-t22dw",
									"text": "were chewing beef.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-66-bomnw",
									"text": "Who was it said\n"
								},
								{
									"_type": "span",
									"_key": "key-68-ems9t",
									"text": "“The wonder of the world",
									"marks": [
										"key-67-r0zki"
									]
								},
								{
									"_type": "span",
									"_key": "key-69-n4ixx",
									"text": "is its comprehensibility”",
									"marks": [
										"key-67-r0zki"
									]
								},
								{
									"_type": "span",
									"_key": "key-70-65qdw",
									"text": "?\n\n"
								},
								{
									"_type": "span",
									"_key": "key-71-hjk95",
									"text": "“Strictly Iowa”\n",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-72-sh8ax",
									"text": "They were married so long\n"
								},
								{
									"_type": "span",
									"_key": "key-73-15uw4",
									"text": "they were worn down\n"
								},
								{
									"_type": "span",
									"_key": "key-74-afp7h",
									"text": "to the same element,\n"
								},
								{
									"_type": "span",
									"_key": "key-75-kqtd7",
									"text": "two factual blue eyes\n"
								},
								{
									"_type": "span",
									"_key": "key-76-46e3s",
									"text": "and an open freckled face\n"
								},
								{
									"_type": "span",
									"_key": "key-77-wu6t4",
									"text": "neither liberal nor conservative\n"
								},
								{
									"_type": "span",
									"_key": "key-78-tgs3l",
									"text": "like the Revolutionary farmer\n"
								},
								{
									"_type": "span",
									"_key": "key-79-z4j8c",
									"text": "and as sparing with an adjective\n"
								},
								{
									"_type": "span",
									"_key": "key-80-hix4p",
									"text": "as a short-haired dog.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-81-ag9oy",
									"text": "“Grace Note”\n",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-82-e1bz4",
									"text": "Since the world\n"
								},
								{
									"_type": "span",
									"_key": "key-83-tp1in",
									"text": "has been my tuning fork\n"
								},
								{
									"_type": "span",
									"_key": "key-84-wiugb",
									"text": "I must have struck\n"
								},
								{
									"_type": "span",
									"_key": "key-85-h8k6y",
									"text": "a note myself\n"
								},
								{
									"_type": "span",
									"_key": "key-86-3xfun",
									"text": "from time to time\n"
								},
								{
									"_type": "span",
									"_key": "key-87-65165",
									"text": "which pays my debt\n"
								},
								{
									"_type": "span",
									"_key": "key-88-af018",
									"text": "with honest affection\n"
								},
								{
									"_type": "span",
									"_key": "key-89-pcv14",
									"text": "undivided between\n"
								},
								{
									"_type": "span",
									"_key": "key-90-ons2c",
									"text": "head and spring."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-40-avjsv",
									"href": "http://www.amazon.com/Ere-Voice-Carl-Rakosi/dp/0876852509"
								},
								{
									"_type": "link",
									"_key": "key-67-r0zki",
									"href": "http://www.kostic.niu.edu/Physics_and_Reality-Albert_Einstein.pdf#page=3"
								}
							]
						}
					]
				}
			},
			{
				"id": "posts:january-2020",
