									"_type": "span",
									"_key": "key-50-vnqxb",
									"text": "Day Roman",
									"marks": [
										"key-49-xmnj6"
									]
								},
								{
									"_type": "span",
									"_key": "key-51-57hfh",
									"text": " as the serif type face and used "
								},
								{
									"_type": "span",
									"_key": "key-53-ixbte",
									"text": "Bickham Script Pro",
									"marks": [
										"key-52-sz0jm"
									]
								},
								{
									"_type": "span",
									"_key": "key-54-pskbp",
									"text": " for our name lettering and "
								},
								{
									"_type": "span",
									"_key": "key-56-26f5b",
									"text": "Mutlu",
									"marks": [
										"key-55-r0xt5"
									]
								},
								{
									"_type": "span",
									"_key": "key-57-4k1nd",
									"text": " (a more expressive, ornamental font) for the initial letters in our names and the ampersand. I made the three lines at the top out of periods and forward and back slashes in the "
								},
								{
									"_type": "span",
									"_key": "key-59-i1bj1",
									"text": "Minion Pro",
