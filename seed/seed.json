									"_type": "link",
									"_key": "key-73-5177t",
									"href": "https://global.oup.com/academic/product/anarchism-a-very-short-introduction-9780192804778?q=anarchism%20colin&lang=en&cc=us",
									"blank": true
								},
								{
									"_type": "link",
									"_key": "key-76-afhif",
									"href": "https://www.theatlantic.com/politics/archive/2017/01/anarchism-intentional-communities-trump/513086/",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-84-lfys6",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-80-gsag1",
									"text": "Inspired by Ward, I decided to finally start David Graeber's "
								},
								{
									"_type": "span",
									"_key": "key-82-sqbcf",
									"text": "Debt: The First 5000 Years",
									"marks": [
										"key-81-2upuv",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-83-k76qf",
									"text": ". More anarchism! I still haven't finished it, but it was so compelling (and disruptive to the way that I'd normalized the 'economic order' of things) that Laurel started reading it as well."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-81-2upuv",
									"href": "https://www.mhpbooks.com/books/debt/",
