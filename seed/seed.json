			{
				"id": "music:24-hour-mega-mix-best-of-march-2013",
				"slug": "24-hour-mega-mix-best-of-march-2013",
				"status": "published",
				"data": {
					"title": "24-Hour MEGA MIX [Best of March 2013]",
					"featured_image": {
						"id": "",
						"provider": "external",
						"src": "https://steelwagstaff.info/wordpress/wp-content/uploads/2013/12/vault-entrance-e1388179585899.jpg"
