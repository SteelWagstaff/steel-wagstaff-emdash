								}
							]
						},
						{
							"_type": "image",
							"_key": "key-199-7c70t",
							"asset": {
								"_type": "reference",
								"_ref": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-625.jpg",
								"url": "http://steelwagstaff.files.wordpress.com/2012/05/steel-and-laurel-625.jpg"
							},
							"alt": ""
