			{
				"id": "pages:about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "About me",
					"content": [
						{
							"_type": "image",
							"_key": "p8uxaw1ro",
							"asset": {
								"_ref": "01KNWJ4PP1YWXJXCC3Y66PKK56",
								"url": "/_emdash/api/media/file/01KNWJ4P6KR56QBC8ZYE3MJE4K.jpg"
							},
							"alt": "Steel Wagstaff",
							"width": 2216,
							"height": 2216,
							"displayWidth": 500,
							"displayHeight": 500
						},
						{
							"_type": "block",
							"_key": "dqfui53d4",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "pohogfiy6",
									"text": "What I do:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "jc6fq985u",
									"text": " Since 2018, I’ve worked for "
								},
								{
									"_type": "span",
									"_key": "rd3fkp68o",
									"text": "Pressbooks",
									"marks": [
										"j2va1z9o6"
									]
								},
								{
									"_type": "span",
									"_key": "23xyqqyp1",
									"text": ", a small Canadian company that makes "
								},
								{
									"_type": "span",
									"_key": "cx2mcky3j",
									"text": "open source book publishing software",
									"marks": [
										"pp01dc0xl"
									]
								},
								{
									"_type": "span",
									"_key": "syxr3y8n7",
									"text": ". I make my home in Eugene, Oregon (kalapuya iliʔi) with my wife, "
								},
								{
									"_type": "span",
									"_key": "zd30v7qty",
									"text": "Laurel Bastian",
									"marks": [
										"ze10s1tc5"
									]
								},
								{
									"_type": "span",
									"_key": "eybecxcrk",
									"text": ", our son, a small dog, and three chickens."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "j2va1z9o6",
									"href": "https://pressbooks.com",
									"blank": true
								},
								{
									"_type": "link",
									"_key": "pp01dc0xl",
									"href": "https://github.com/pressbooks",
									"blank": true
								},
								{
									"_type": "link",
									"_key": "ze10s1tc5",
									"href": "https://teaching.uoregon.edu/about/tep-staff-directory#:~:text=Laurel%20Bastian,-Associate%20Director",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "psg9wbqf3",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "lyeyw31wt",
									"text": "What I’ve done:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "ekg2exjbz",
									"text": " Before joining Pressbooks, I taught writing and literature to college students and incarcerated men, served as a instructional designer and pedagogy consultant for university teachers, built websites, and worked as a land surveyor."
								}
							]
						},
						{
							"_type": "block",
							"_key": "s3l653w5c",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "9f81twnvs",
									"text": "What I love:",
									"marks": [
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "po6uaalxs",
									"text": " Being a father, partner, and friend. Reading poetry (especially "
								},
								{
									"_type": "span",
									"_key": "rerwm390x",
									"text": "the ‘Objectivists’",
									"marks": [
										"jg5kgbjgo"
									]
								},
								{
									"_type": "span",
									"_key": "k6puarpt7",
									"text": ") and  listening to good "
								},
								{
									"_type": "span",
									"_key": "9oi1g1k63",
									"text": "music",
									"marks": [
										"1iotodly5"
									]
								},
								{
									"_type": "span",
									"_key": "f9aszknl8",
									"text": ". Trying to live “in a good way” in the present moment. Visiting libraries, playing pickup soccer, eating vegetarian food. Collaborating with others to address problems we face in our daily life without resorting to violence or domination (anarchism, basically). Developing more generosity, curiosity, and compassion for all sentient beings. "
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "jg5kgbjgo",
									"href": "https://theobjectivists.org",
									"blank": true
								},
								{
									"_type": "link",
									"_key": "1iotodly5",
									"href": "/music/",
									"blank": true
								}
							]
						}
					],
					"excerpt": ""
				}
			},
