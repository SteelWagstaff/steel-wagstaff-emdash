								}
							]
						},
						{
							"_type": "block",
							"_key": "key-111-hegtl",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-108-bxlcf",
									"text": "Living With Less. A Lot Less.",
									"marks": [
										"key-107-f5rbl",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-109-thr6z",
									"text": " by GRAHAM HILL",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-110-yaxg0",
									"text": "I LIVE in a 420-square-foot studio. I sleep in a bed that folds down from the wall. I have six dress shirts. I have 10 shallow bowls that I use for salads and main dishes. When people come over for dinner, I pull out my extendable dining room table.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-107-f5rbl",
									"href": "http://www.nytimes.com/2013/03/10/opinion/sunday/living-with-less-a-lot-less.html?nl=todaysheadlines&emc=edit_th_20130310&_r=0&pagewanted=all"
