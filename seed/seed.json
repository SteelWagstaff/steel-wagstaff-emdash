							]
						},
						{
							"_type": "block",
							"_key": "key-50-nrvso",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-46-am6ll",
									"text": "Sheila Bair's "
								},
								{
									"_type": "span",
									"_key": "key-48-wvogy",
									"text": "Bull By the Horns",
									"marks": [
										"em",
										"key-47-28ohf"
									]
								},
								{
									"_type": "span",
									"_key": "key-49-aze3a",
									"text": ". Fascinating insider's account of the Bush and Obama administration's response to the recent financial crisis and essential failure of meaningful regulatory oversight by several federal agencies. Bair was the former chairperson of the FDIC and has been much lauded as a fierce consumer advocate."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-47-28ohf",
									"href": "http://www.simonandschuster.com/books/Bull-by-the-Horns/Sheila-Bair/9781451672497",
									"blank": true
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-55-c6f30",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-51-cs9px",
									"text": "Burton Malkiel's "
								},
								{
									"_type": "span",
									"_key": "key-53-ar4ba",
									"text": "A Random Walk Down Wall Street",
									"marks": [
										"em",
										"key-52-1ttqf"
									]
								},
								{
									"_type": "span",
									"_key": "key-54-s1621",
									"text": ". I thought I'd like this much more than I actually did. Worth reading, but I appreciated the other books on the list more, I think."
								}
							],
							"markDefs": [
								{
									"_type": "link",
