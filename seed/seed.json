							]
						},
						{
							"_type": "block",
							"_key": "key-66-d4heq",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-62-oofkp",
									"text": "Geraldine Pinch's "
								},
								{
									"_type": "span",
									"_key": "key-64-1i4yz",
									"text": "Egyptian Myth",
									"marks": [
										"key-63-llddg",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-65-8bvb2",
									"text": ". Quite good. I actually felt like I managed to learn more about Egyptian history and culture from this book than the previous one, despite it being less central to the book's ostensible purpose."
								}
							],
							"markDefs": [
								{
