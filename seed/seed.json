								}
							]
						},
						{
							"_type": "block",
							"_key": "key-141-11lya",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-138-yw115",
									"text": "Kircher’s Cosmos: On Athanasius Kircher | The Nation",
									"marks": [
										"key-137-jpsz0",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-139-wsqpg",
									"text": " by John Glassie.",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-140-ggdnz",
									"text": "In 1680, a small procession of Jesuits ascended a winding path to the mountaintop shrine of Mentorella, some thirty miles east of Rome.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
