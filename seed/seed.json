								}
							]
						},
						{
							"_type": "block",
							"_key": "key-146-7y2qt",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-143-a57u1",
									"text": "What Do Scientific Studies Show?",
									"marks": [
										"key-142-n8rva",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-144-9bag8",
									"text": " by GARY GUTTING",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-145-92mcw",
									"text": "As any regular reader of news will know, popular media report “scientific results” nearly every day.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-142-n8rva",
									"href": "http://opinionator.blogs.nytimes.com/2013/04/25/what-do-scientific-studies-show/?src=recg"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-151-6kipa",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-148-gtscy",
									"text": "Depression’s Upside - NYTimes.com",
									"marks": [
										"key-147-2r0kt",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-149-8n44u",
									"text": " by JONAH LEHRER",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-150-u2m90",
									"text": "The Victorians had many names for depression, and Charles Darwin used them all. There were his “fits” brought on by “excitements,” “flurries” leading to an “uncomfortable palpitation of the heart” and “air fatigues” that triggered his “head symptoms.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-147-2r0kt",
									"href": "http://www.nytimes.com/2010/02/28/magazine/28depression-t.html?_r=1&em=&pagewanted=all"
								}
							]
						},
						{
							"_type": "block",
							"_key": "key-156-i0i2s",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-153-vtnwo",
									"text": "The Social Center: Why Writing Centers Need Twitter",
