						{
							"_type": "block",
							"_key": "key-52-zadwx",
							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-49-btuf4",
									"text": "Seeing and Believing",
									"marks": [
										"key-48-gmsuu",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-50-k6ofg",
									"text": " by SUSANNE KLINGENSTEIN",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-51-omgbn",
									"text": "In 1935, Ernst Gombrich, scion of a bourgeois Viennese Jewish family, and newly minted Ph.D. in art history, found himself out of work. Walter Neurath, a friend and publisher, asked him to look over an English history book for children and, if it was any good, to translate it into German.",
									"marks": [
										"strong"
									]
								}
							],
							"markDefs": [
								{
