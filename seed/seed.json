							"_key": "key-159-inoq8",
							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-153-3dfgy",
									"text": "\""
								},
								{
									"_type": "span",
									"_key": "key-155-f4dpg",
									"text": "I Used to Be A Human Being",
									"marks": [
										"key-154-tvui0"
									]
								},
								{
									"_type": "span",
									"_key": "key-156-7jeof",
									"text": ",\" Andrew Sullivan's recent meditation in "
								},
								{
									"_type": "span",
									"_key": "key-157-28gnh",
									"text": "New York ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-158-gbqgk",
									"text": "magazineon the human price of constant connection to our devices. I don't typically read (or recommend!) Sullivan, but ..."
								}
							],
							"markDefs": [
