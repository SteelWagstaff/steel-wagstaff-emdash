							"style": "normal",
							"listItem": "bullet",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-64-y0win",
									"text": "‘Constant Drumbeat’ Sped the Pope’s Exit",
									"marks": [
										"key-63-z6hyy",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-65-332oz",
									"text": " by RACHEL DONADIO",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-66-b6f1r",
									"text": "VATICAN CITY — Just days after Pope Benedict XVI returned from a 2010 trip to Britain where he met the queen and mended fences with the Anglicans, prosecutors in Rome impounded $30 million from the Vatican Bank in an investigation linked to money laundering.",
									"marks": [
										"strong"
									]
