									"_key": "key-60-7i0i0",
									"text": " typeface, and designed the interlocking rings at the top and lines of dots surrounding the ampersand in Illustrator.\n\n"
								},
								{
									"_type": "span",
									"_key": "key-61-qlkiw",
									"text": "[caption id=\"attachment_963\" align=\"alignleft\" width=\"500\"]"
								}
