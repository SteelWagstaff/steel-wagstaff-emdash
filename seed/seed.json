							"style": "normal",
							"children": [
								{
									"_type": "span",
									"_key": "key-131-70zev",
									"text": "The mathematical equation that caused the banks to crash",
									"marks": [
										"key-130-mxeow",
										"strong"
									]
								},
								{
									"_type": "span",
