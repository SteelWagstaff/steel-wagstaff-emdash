								{
									"_type": "span",
									"_key": "key-48-yee6z",
									"text": " One of Laurel's shoes on a bookcase in our living room.[/caption]\n\n"
								},
								{
									"_type": "span",
									"_key": "key-49-7ceu9",
									"text": "[caption id=\"attachment_1200\" align=\"alignleft\" width=\"500\"]"
								}
