							"style": "normal",
							"listItem": "number",
							"level": 1,
							"children": [
								{
									"_type": "span",
									"_key": "key-23-4xdvp",
									"text": "Guantánamo Diary",
									"marks": [
										"em",
										"key-22-s7ynz"
									]
								},
								{
									"_type": "span",
									"_key": "key-24-r5s93",
									"text": " ",
									"marks": [
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-25-3aimm",
									"text": "by Mohamedou Ould Slahi, edited by Larry Siems. The account of the detainment and torture of Slahi, a Mauritanian national held without charges by the United States for around 15 years. Slahi was released last month and is now living with his family in Mauritania. Read on recommendation from my friend Phil."
								}
							],
							"markDefs": [
								{
									"_type": "link",
									"_key": "key-22-s7ynz",
									"href": "http://guantanamodiary.com/",
