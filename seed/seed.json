							"children": [
								{
									"_type": "span",
									"_key": "key-34-98fkw",
									"text": "Tupac Lane Welcomes You: The Street Names Of Las Vegas",
									"marks": [
										"key-33-2arfu",
										"strong"
									]
								},
								{
									"_type": "span",
									"_key": "key-35-25sg6",
									"text": " by Willy Staley",
									"marks": [
										"strong",
										"em"
									]
								},
								{
									"_type": "span",
									"_key": "key-36-3r2f3",
									"text": "When Tupac was riddled with bullets just off the Las Vegas Strip in 1996, yet another city was added to the long list of those that have claims on him: Baltimore, Oakland, New York, Los Angeles, Marin City.1 As the list’s last entry, Las Vegas became the one people would least like to remember.",
									"marks": [
										"strong"
									]
